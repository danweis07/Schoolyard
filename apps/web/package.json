{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && tsx ../../scripts/generate-manifest.ts && pagefind --site dist",
    "build:manifest": "tsx ../../scripts/generate-manifest.ts",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint src",
    "typecheck": "astro check",
    "test": "vitest run",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/node": "^10.0.4",
    "@astrojs/rss": "^4.0.9",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/tailwind": "^5.1.2",
    "@schoolyard/config": "workspace:*",
    "@schoolyard/content-api": "workspace:*",
    "@schoolyard/i18n": "workspace:*",
    "@schoolyard/supabase": "workspace:*",
    "@schoolyard/tokens": "workspace:*",
    "astro": "^5.0.0",
    "astro-icon": "^1.1.5",
    "tailwindcss": "^3.4.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@iconify-json/heroicons": "^1.2.1",
    "@playwright/test": "^1.59.1",
    "pagefind": "^1.1.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
