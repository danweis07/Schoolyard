---
interface Props {
  href?: string
  variant?: 'primary' | 'secondary' | 'outline'
  type?: 'button' | 'submit' | 'reset'
  class?: string
}

const { href, variant = 'primary', type = 'button', class: className = '' } = Astro.props

const variantClasses = {
  primary: 'bg-primary text-inverse hover:opacity-90',
  secondary: 'bg-accent text-base hover:opacity-90',
  outline: 'border border-primary text-primary bg-transparent hover:bg-primary hover:text-inverse',
}[variant]

const classes =
  'inline-flex items-center justify-center rounded-button px-5 py-2.5 font-semibold no-underline transition ' +
  variantClasses +
  ' ' +
  className
---

{
  href ? (
    <a href={href} class={classes}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes}>
      <slot />
    </button>
  )
}
