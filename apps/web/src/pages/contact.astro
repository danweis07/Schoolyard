---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { siteConfig } from '@/lib/site'
import { useTranslate, getLocaleFromUrl } from '@/i18n/index'

const locale = getLocaleFromUrl(Astro.url)
const t = useTranslate(locale)
---

<BaseLayout title={t('contact.title')} description={t('contact.description')}>
  <section class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-4xl font-bold">{t('contact.title')}</h1>
    <p class="mt-2 text-lg text-muted">{t('contact.description')}</p>

    <div class="mt-8 grid gap-8 md:grid-cols-2">
      <div>
        <h2 class="text-xl font-bold">{siteConfig.school.name}</h2>
        <ul class="mt-4 space-y-2 text-base">
          {
            siteConfig.school.address && (
              <li>
                <strong class="text-muted">{t('footer.address')}:</strong>{' '}
                {siteConfig.school.address}
              </li>
            )
          }
          {
            siteConfig.school.phone && (
              <li>
                <strong class="text-muted">{t('footer.phone')}:</strong>{' '}
                <a href={`tel:${siteConfig.school.phone}`}>{siteConfig.school.phone}</a>
              </li>
            )
          }
          {
            siteConfig.school.email && (
              <li>
                <strong class="text-muted">{t('footer.email')}:</strong>{' '}
                <a href={`mailto:${siteConfig.school.email}`}>{siteConfig.school.email}</a>
              </li>
            )
          }
        </ul>
      </div>

      <form
        name="contact"
        method="POST"
        data-netlify="true"
        class="rounded-card border border-border bg-surface p-card"
      >
        <input type="hidden" name="form-name" value="contact" />

        <label class="block">
          <span class="text-sm font-semibold">{t('contact.form.name')}</span>
          <input
            type="text"
            name="name"
            required
            class="mt-1 block w-full rounded-button border border-border bg-surface px-3 py-2"
          />
        </label>

        <label class="mt-4 block">
          <span class="text-sm font-semibold">{t('contact.form.email')}</span>
          <input
            type="email"
            name="email"
            required
            class="mt-1 block w-full rounded-button border border-border bg-surface px-3 py-2"
          />
        </label>

        <label class="mt-4 block">
          <span class="text-sm font-semibold">{t('contact.form.subject')}</span>
          <input
            type="text"
            name="subject"
            class="mt-1 block w-full rounded-button border border-border bg-surface px-3 py-2"
          />
        </label>

        <label class="mt-4 block">
          <span class="text-sm font-semibold">{t('contact.form.message')}</span>
          <textarea
            name="message"
            rows="4"
            required
            class="mt-1 block w-full rounded-button border border-border bg-surface px-3 py-2"
          ></textarea>
        </label>

        <button
          type="submit"
          class="mt-6 rounded-button bg-primary px-6 py-2.5 font-semibold text-inverse hover:opacity-90"
        >
          {t('contact.form.send')}
        </button>
      </form>
    </div>
  </section>
</BaseLayout>
