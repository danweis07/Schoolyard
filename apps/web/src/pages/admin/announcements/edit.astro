---
/**
 * Admin announcement editor — create or edit a single announcement.
 *
 * When `?id=<uuid>` is present, loads the existing announcement for editing.
 * Otherwise renders a blank form for creating a new announcement.
 *
 * Announcements have a draft/sent lifecycle: sent_at is null for drafts.
 * The "Send Now" button sets sent_at to the current timestamp. The regular
 * "Save" button keeps it as a draft.
 *
 * All mutations happen client-side via the browser Supabase client.
 * RLS on the announcements table enforces that only editors/admins for the
 * matching school_id can insert or update rows.
 */
import BaseLayout from '@/layouts/BaseLayout.astro'

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? import.meta.env.SUPABASE_URL ?? ''
const supabaseAnon =
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? import.meta.env.SUPABASE_ANON_KEY ?? ''
---

<BaseLayout title="Admin - Edit Announcement" description="Create or edit an announcement">
  <div
    class="mx-auto max-w-3xl px-4 py-8"
    data-sy-admin
    data-supabase-url={supabaseUrl}
    data-supabase-anon={supabaseAnon}
  >
    <!-- Auth gate -->
    <div id="admin-auth-gate" class="hidden py-16 text-center">
      <h1 class="text-3xl font-bold">Sign in required</h1>
      <p class="mt-2 text-muted">
        You need to be signed in as an editor or admin to edit announcements.
      </p>
      <a
        href={`/sign-in?redirect=/admin/announcements/edit`}
        class="mt-6 inline-block rounded-button bg-primary px-6 py-3 text-sm font-bold text-inverse hover:opacity-90"
      >
        Sign in
      </a>
    </div>

    <!-- Form -->
    <div id="admin-content" class="hidden">
      <nav class="text-sm text-muted" aria-label="Breadcrumb">
        <a href="/admin/" class="hover:underline">Admin</a>
        <span class="mx-1" aria-hidden="true">/</span>
        <a href="/admin/announcements/" class="hover:underline">Announcements</a>
        <span class="mx-1" aria-hidden="true">/</span>
        <span id="breadcrumb-action">New</span>
      </nav>
      <h1 class="mt-1 text-2xl font-bold" id="page-title">New Announcement</h1>

      <!-- Status badge for sent announcements -->
      <div id="sent-badge" class="mt-2 hidden">
        <span class="inline-block rounded-button bg-success/15 px-2 py-0.5 text-xs font-medium"
          >Sent</span
        >
        <span id="sent-date" class="ml-1 text-xs text-muted"></span>
      </div>

      <!-- Status messages -->
      <div id="form-message" class="mt-4 hidden rounded-card p-4 text-sm" role="alert"></div>

      <form id="announcement-form" class="mt-6 space-y-6" novalidate>
        <!-- Title -->
        <div>
          <label for="field-title" class="block text-sm font-medium"
            >Title <span class="text-error" aria-hidden="true">*</span></label
          >
          <input
            id="field-title"
            type="text"
            required
            class="mt-1 block w-full rounded-button border border-border bg-surface px-4 py-2.5 text-base placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            placeholder="Important School Update"
          />
        </div>

        <!-- Body -->
        <div>
          <label for="field-body" class="block text-sm font-medium"
            >Body <span class="text-error" aria-hidden="true">*</span></label
          >
          <textarea
            id="field-body"
            rows="10"
            required
            class="mt-1 block w-full rounded-button border border-border bg-surface px-4 py-2.5 text-sm font-mono placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            placeholder="Write the announcement body..."></textarea>
        </div>

        <!-- Action buttons -->
        <div class="flex flex-wrap items-center gap-3 border-t border-border pt-6">
          <button
            type="submit"
            id="btn-save"
            class="rounded-button bg-primary px-6 py-2.5 text-sm font-bold text-inverse hover:opacity-90 disabled:opacity-60"
          >
            Save Draft
          </button>
          <button
            type="button"
            id="btn-send"
            class="rounded-button bg-success px-6 py-2.5 text-sm font-bold text-inverse hover:opacity-90 disabled:opacity-60"
          >
            Send Now
          </button>
          <a
            href="/admin/announcements/"
            class="rounded-button border border-border px-6 py-2.5 text-sm font-semibold hover:bg-muted/10"
          >
            Cancel
          </a>
          <button
            type="button"
            id="btn-delete"
            class="ml-auto hidden rounded-button border border-error px-6 py-2.5 text-sm font-semibold text-error hover:bg-error/10 disabled:opacity-60"
          >
            Delete
          </button>
        </div>
      </form>
    </div>

    <!-- Loading -->
    <div id="admin-loading" class="py-16 text-center">
      <p class="text-muted">Loading...</p>
    </div>
  </div>
</BaseLayout>

<script>
  // @ts-nocheck
  import { createBrowserClient } from '@schoolyard/supabase/browser'

  const root = document.querySelector<HTMLElement>('[data-sy-admin]')!
  const url = root.dataset.supabaseUrl ?? ''
  const anon = root.dataset.supabaseAnon ?? ''

  const loadingEl = document.getElementById('admin-loading')!
  const authGate = document.getElementById('admin-auth-gate')!
  const content = document.getElementById('admin-content')!
  const form = document.getElementById('announcement-form') as HTMLFormElement
  const msgEl = document.getElementById('form-message')!
  const pageTitle = document.getElementById('page-title')!
  const breadcrumbAction = document.getElementById('breadcrumb-action')!
  const btnSave = document.getElementById('btn-save') as HTMLButtonElement
  const btnSend = document.getElementById('btn-send') as HTMLButtonElement
  const btnDelete = document.getElementById('btn-delete') as HTMLButtonElement
  const sentBadge = document.getElementById('sent-badge')!
  const sentDate = document.getElementById('sent-date')!

  // Field references
  const f = {
    title: document.getElementById('field-title') as HTMLInputElement,
    body: document.getElementById('field-body') as HTMLTextAreaElement,
  }

  function showView(id: 'loading' | 'auth' | 'content') {
    loadingEl.classList.toggle('hidden', id !== 'loading')
    authGate.classList.toggle('hidden', id !== 'auth')
    content.classList.toggle('hidden', id !== 'content')
  }

  function showMsg(text: string, type: 'success' | 'error') {
    msgEl.textContent = text
    msgEl.className =
      type === 'success'
        ? 'mt-4 rounded-card p-4 text-sm bg-success/10 border border-success/30'
        : 'mt-4 rounded-card p-4 text-sm bg-error/10 border border-error/30 text-error'
  }

  function formatDate(iso: string): string {
    try {
      return new Date(iso).toLocaleDateString(undefined, {
        month: 'short',
        day: 'numeric',
        year: 'numeric',
        hour: 'numeric',
        minute: '2-digit',
      })
    } catch {
      return iso
    }
  }

  if (!url || !anon) {
    showView('auth')
  } else {
    const supabase = createBrowserClient({ url, anonKey: anon })
    const params = new URLSearchParams(window.location.search)
    const editId = params.get('id')
    let schoolId = ''
    let userId = ''
    let currentSentAt: string | null = null

    async function init() {
      const {
        data: { user },
      } = await supabase.auth.getUser()
      if (!user) {
        showView('auth')
        return
      }

      userId = user.id

      const { data: profile } = await supabase
        .from('profiles')
        .select('school_id, role')
        .eq('id', user.id)
        .maybeSingle()

      const allowed = ['editor', 'admin', 'district_admin']
      if (!profile?.school_id || !allowed.includes(profile.role)) {
        showView('auth')
        return
      }

      schoolId = profile.school_id
      showView('content')

      // If editing, load the announcement
      if (editId) {
        pageTitle.textContent = 'Edit Announcement'
        breadcrumbAction.textContent = 'Edit'
        btnDelete.classList.remove('hidden')

        const { data: ann, error } = await supabase
          .from('announcements')
          .select('*')
          .eq('id', editId)
          .eq('school_id', schoolId)
          .maybeSingle()

        if (error || !ann) {
          showMsg(error?.message ?? 'Announcement not found', 'error')
          return
        }

        f.title.value = ann.title ?? ''
        f.body.value = ann.body ?? ''
        currentSentAt = ann.sent_at ?? null

        // If already sent, show the badge and hide Send Now button
        if (ann.sent_at) {
          sentBadge.classList.remove('hidden')
          sentDate.textContent = formatDate(ann.sent_at)
          btnSend.classList.add('hidden')
          btnSave.textContent = 'Save Announcement'
        }
      }
    }

    // Save handler (save as draft)
    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      await saveAnnouncement(false)
    })

    // Send Now handler
    btnSend.addEventListener('click', async () => {
      if (!confirm('Send this announcement now? This will mark it as sent.')) return
      await saveAnnouncement(true)
    })

    async function saveAnnouncement(sendNow: boolean) {
      // Validate required fields
      if (!f.title.value.trim()) {
        showMsg('Title is required.', 'error')
        f.title.focus()
        return
      }
      if (!f.body.value.trim()) {
        showMsg('Body is required.', 'error')
        f.body.focus()
        return
      }

      btnSave.disabled = true
      btnSend.disabled = true
      btnSave.textContent = 'Saving...'

      const row: Record<string, unknown> = {
        school_id: schoolId,
        title: f.title.value.trim(),
        body: f.body.value.trim(),
      }

      // Set sent_at if sending now (only if not already sent)
      if (sendNow && !currentSentAt) {
        row.sent_at = new Date().toISOString()
      }

      // Set created_by on insert
      if (!editId) {
        row.created_by = userId
      }

      let result
      if (editId) {
        result = await supabase
          .from('announcements')
          .update(row)
          .eq('id', editId)
          .eq('school_id', schoolId)
      } else {
        result = await supabase.from('announcements').insert(row).select('id').single()
      }

      btnSave.disabled = false
      btnSend.disabled = false
      btnSave.textContent = currentSentAt ? 'Save Announcement' : 'Save Draft'

      if (result.error) {
        showMsg(`Save failed: ${result.error.message}`, 'error')
        return
      }

      if (sendNow && !currentSentAt) {
        showMsg('Announcement sent successfully.', 'success')
        currentSentAt = row.sent_at as string
        sentBadge.classList.remove('hidden')
        sentDate.textContent = formatDate(currentSentAt)
        btnSend.classList.add('hidden')
        btnSave.textContent = 'Save Announcement'
      } else {
        showMsg('Announcement saved successfully.', 'success')
      }

      // If creating, redirect to the edit page for the new record
      if (!editId && result.data?.id) {
        setTimeout(() => {
          window.location.href = `/admin/announcements/edit?id=${result.data.id}`
        }, 600)
      }
    }

    // Delete handler
    btnDelete.addEventListener('click', async () => {
      if (!editId) return
      if (!confirm('Delete this announcement? This cannot be undone.')) return

      btnDelete.disabled = true
      btnDelete.textContent = 'Deleting...'

      const { error } = await supabase
        .from('announcements')
        .delete()
        .eq('id', editId)
        .eq('school_id', schoolId)

      if (error) {
        showMsg(`Delete failed: ${error.message}`, 'error')
        btnDelete.disabled = false
        btnDelete.textContent = 'Delete'
        return
      }

      window.location.href = '/admin/announcements/'
    })

    init()
  }
</script>
