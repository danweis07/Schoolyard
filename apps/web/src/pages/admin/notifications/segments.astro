---
/**
 * Admin audience segment manager — list existing segments and create new ones.
 *
 * Segments define targeted audiences for notifications (e.g., "K-2 parents",
 * "Bus Route 5", "Spanish speakers").
 */
import BaseLayout from '@/layouts/BaseLayout.astro'
import { siteConfig } from '@/lib/site'

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? import.meta.env.SUPABASE_URL ?? ''
const supabaseAnon =
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? import.meta.env.SUPABASE_ANON_KEY ?? ''
const schoolSlug = siteConfig.school.shortName.toLowerCase().replace(/[^a-z0-9]+/g, '-')
---

<BaseLayout title="Admin - Audience Segments" description="Manage notification audience segments">
  <div
    class="mx-auto max-w-5xl px-4 py-8"
    data-sy-admin
    data-supabase-url={supabaseUrl}
    data-supabase-anon={supabaseAnon}
    data-school-slug={schoolSlug}
  >
    <!-- Auth gate -->
    <div id="admin-auth-gate" class="hidden py-16 text-center">
      <h1 class="text-3xl font-bold">Sign in required</h1>
      <p class="mt-2 text-muted">
        You need to be signed in as an editor or admin to manage segments.
      </p>
      <a
        href="/sign-in?redirect=/admin/notifications/segments"
        class="mt-6 inline-block rounded-button bg-primary px-6 py-3 text-sm font-bold text-inverse hover:opacity-90"
      >
        Sign in
      </a>
    </div>

    <!-- Main content -->
    <div id="admin-content" class="hidden">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <nav class="text-sm text-muted" aria-label="Breadcrumb">
            <a href="/admin/" class="hover:underline">Admin</a>
            <span class="mx-1" aria-hidden="true">/</span>
            <a href="/admin/notifications/" class="hover:underline">Notifications</a>
            <span class="mx-1" aria-hidden="true">/</span>
            <span>Segments</span>
          </nav>
          <h1 class="mt-1 text-2xl font-bold">Audience Segments</h1>
        </div>
      </div>

      <!-- Create segment form -->
      <div class="mt-6 rounded-card border border-border bg-surface p-card">
        <h2 class="text-lg font-semibold">Create Segment</h2>
        <div id="segment-message" class="mt-2 hidden rounded-card p-4 text-sm" role="alert"></div>
        <form id="segment-form" class="mt-4 space-y-4" novalidate>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="field-name" class="block text-sm font-medium">
                Name <span class="text-error" aria-hidden="true">*</span>
              </label>
              <input
                id="field-name"
                type="text"
                required
                class="mt-1 block w-full rounded-button border border-border bg-surface px-4 py-2.5 text-base placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                placeholder="K-2 Parents"
              />
            </div>
            <div>
              <label for="field-slug" class="block text-sm font-medium">
                Slug <span class="text-error" aria-hidden="true">*</span>
              </label>
              <input
                id="field-slug"
                type="text"
                required
                class="mt-1 block w-full rounded-button border border-border bg-surface px-4 py-2.5 text-sm font-mono placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                placeholder="k-2-parents"
              />
            </div>
          </div>
          <div>
            <label for="field-description" class="block text-sm font-medium">Description</label>
            <input
              id="field-description"
              type="text"
              class="mt-1 block w-full rounded-button border border-border bg-surface px-4 py-2.5 text-base placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
              placeholder="Parents of kindergarten through 2nd grade students"
            />
          </div>
          <div class="flex items-center gap-3">
            <button
              type="submit"
              id="btn-create"
              class="rounded-button bg-primary px-6 py-2.5 text-sm font-bold text-inverse hover:opacity-90 disabled:opacity-60"
            >
              Create Segment
            </button>
          </div>
        </form>
      </div>

      <!-- Segments table -->
      <h2 class="mt-8 text-lg font-bold">Existing Segments</h2>
      <div class="mt-4 overflow-x-auto rounded-card border border-border">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="border-b border-border bg-muted/5">
              <th class="px-4 py-3 font-semibold" scope="col">Name</th>
              <th class="hidden px-4 py-3 font-semibold sm:table-cell" scope="col">Slug</th>
              <th class="hidden px-4 py-3 font-semibold md:table-cell" scope="col">Members</th>
              <th class="px-4 py-3 text-right font-semibold" scope="col">
                <span class="sr-only">Actions</span>
              </th>
            </tr>
          </thead>
          <tbody id="segments-tbody">
            <tr>
              <td class="px-4 py-8 text-center text-muted" colspan="4">Loading segments...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Loading -->
    <div id="admin-loading" class="py-16 text-center">
      <p class="text-muted">Loading...</p>
    </div>
  </div>
</BaseLayout>

<script>
  // @ts-nocheck
  import { createBrowserClient } from '@schoolyard/supabase/browser'
  import { createAdminClient } from '@/lib/admin-client'

  const root = document.querySelector<HTMLElement>('[data-sy-admin]')!
  const url = root.dataset.supabaseUrl ?? ''
  const anon = root.dataset.supabaseAnon ?? ''

  const loadingEl = document.getElementById('admin-loading')!
  const authGate = document.getElementById('admin-auth-gate')!
  const content = document.getElementById('admin-content')!
  const tbody = document.getElementById('segments-tbody')!
  const form = document.getElementById('segment-form') as HTMLFormElement
  const msgEl = document.getElementById('segment-message')!
  const btnCreate = document.getElementById('btn-create') as HTMLButtonElement

  function showView(id: 'loading' | 'auth' | 'content') {
    loadingEl.classList.toggle('hidden', id !== 'loading')
    authGate.classList.toggle('hidden', id !== 'auth')
    content.classList.toggle('hidden', id !== 'content')
  }

  function showMsg(text: string, type: 'success' | 'error') {
    msgEl.textContent = text
    msgEl.className =
      type === 'success'
        ? 'mt-2 rounded-card p-4 text-sm bg-success/10 border border-success/30'
        : 'mt-2 rounded-card p-4 text-sm bg-error/10 border border-error/30 text-error'
  }

  function escapeHtml(str: string): string {
    const d = document.createElement('div')
    d.textContent = str
    return d.innerHTML
  }

  if (!url || !anon) {
    showView('auth')
  } else {
    const authClient = createBrowserClient({ url, anonKey: anon })

    let admin: ReturnType<typeof createAdminClient>

    async function checkAuth(): Promise<boolean> {
      const {
        data: { session },
      } = await authClient.auth.getSession()
      if (!session) {
        showView('auth')
        return false
      }

      admin = createAdminClient({
        gatewayUrl: url,
        accessToken: session.access_token,
        schoolSlug: root.dataset.schoolSlug ?? '',
      })

      const { data: profile, error } = await admin.getProfile()
      if (error || !profile?.school_id) {
        showView('auth')
        return false
      }

      const allowed = ['editor', 'admin', 'district_admin']
      if (!allowed.includes(profile.role)) {
        showView('auth')
        return false
      }

      return true
    }

    async function loadSegments() {
      const { data: segments, error } = await admin.list<{
        id: string
        name: string
        slug: string
        description: string | null
        member_count: number
      }>('notification_segments')

      if (error || !segments) {
        tbody.innerHTML = `<tr><td class="px-4 py-8 text-center text-error" colspan="4">Failed to load segments: ${escapeHtml(error ?? 'Unknown error')}</td></tr>`
        return
      }

      if (segments.length === 0) {
        tbody.innerHTML = `<tr><td class="px-4 py-8 text-center text-muted" colspan="4">No segments yet. Create one above.</td></tr>`
        return
      }

      tbody.innerHTML = segments
        .map(
          (s) => `<tr class="border-b border-border last:border-0 hover:bg-muted/5">
          <td class="px-4 py-3">
            <span class="font-medium">${escapeHtml(s.name)}</span>
            ${s.description ? `<p class="mt-0.5 text-xs text-muted">${escapeHtml(s.description)}</p>` : ''}
          </td>
          <td class="hidden px-4 py-3 font-mono text-sm text-muted sm:table-cell">${escapeHtml(s.slug)}</td>
          <td class="hidden px-4 py-3 text-muted md:table-cell">${s.member_count ?? 0}</td>
          <td class="px-4 py-3 text-right">
            <button type="button" data-delete="${s.id}" data-title="${escapeHtml(s.name)}" class="text-sm font-semibold text-error hover:underline">Delete</button>
          </td>
        </tr>`,
        )
        .join('')

      // Attach delete handlers
      tbody.querySelectorAll<HTMLButtonElement>('[data-delete]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const id = btn.dataset.delete!
          const title = btn.dataset.title ?? 'this segment'
          if (!confirm(`Delete segment "${title}"? This cannot be undone.`)) return

          btn.disabled = true
          btn.textContent = 'Deleting...'

          const { error: delErr } = await admin.remove('notification_segments', id)
          if (delErr) {
            alert(`Failed to delete: ${delErr}`)
            btn.disabled = false
            btn.textContent = 'Delete'
          } else {
            loadSegments()
          }
        })
      })
    }

    // Create handler
    form.addEventListener('submit', async (e) => {
      e.preventDefault()

      const name = (document.getElementById('field-name') as HTMLInputElement).value.trim()
      const slug = (document.getElementById('field-slug') as HTMLInputElement).value.trim()
      const description = (document.getElementById('field-description') as HTMLInputElement).value.trim()

      if (!name) {
        showMsg('Name is required.', 'error')
        return
      }
      if (!slug) {
        showMsg('Slug is required.', 'error')
        return
      }

      btnCreate.disabled = true
      btnCreate.textContent = 'Creating...'

      const { error } = await admin.create('notification_segments', {
        name,
        slug,
        description: description || null,
      })

      btnCreate.disabled = false
      btnCreate.textContent = 'Create Segment'

      if (error) {
        showMsg(`Failed to create: ${error}`, 'error')
        return
      }

      showMsg('Segment created.', 'success')
      form.reset()
      loadSegments()
    })

    async function init() {
      if (await checkAuth()) {
        showView('content')
        loadSegments()
      }
    }

    init()
  }
</script>
