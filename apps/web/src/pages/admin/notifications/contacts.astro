---
/**
 * Admin phone-only contact manager — list contacts and add new ones.
 *
 * Contacts have phone, name, email, and locale. Used for SMS/push
 * notification delivery targeting.
 */
import BaseLayout from '@/layouts/BaseLayout.astro'
import { siteConfig } from '@/lib/site'

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? import.meta.env.SUPABASE_URL ?? ''
const supabaseAnon =
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? import.meta.env.SUPABASE_ANON_KEY ?? ''
const schoolSlug = siteConfig.school.shortName.toLowerCase().replace(/[^a-z0-9]+/g, '-')
---

<BaseLayout title="Admin - Notification Contacts" description="Manage notification contacts">
  <div
    class="mx-auto max-w-5xl px-4 py-8"
    data-sy-admin
    data-supabase-url={supabaseUrl}
    data-supabase-anon={supabaseAnon}
    data-school-slug={schoolSlug}
  >
    <!-- Auth gate -->
    <div id="admin-auth-gate" class="hidden py-16 text-center">
      <h1 class="text-3xl font-bold">Sign in required</h1>
      <p class="mt-2 text-muted">
        You need to be signed in as an editor or admin to manage contacts.
      </p>
      <a
        href="/sign-in?redirect=/admin/notifications/contacts"
        class="mt-6 inline-block rounded-button bg-primary px-6 py-3 text-sm font-bold text-inverse hover:opacity-90"
      >
        Sign in
      </a>
    </div>

    <!-- Main content -->
    <div id="admin-content" class="hidden">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <nav class="text-sm text-muted" aria-label="Breadcrumb">
            <a href="/admin/" class="hover:underline">Admin</a>
            <span class="mx-1" aria-hidden="true">/</span>
            <a href="/admin/notifications/" class="hover:underline">Notifications</a>
            <span class="mx-1" aria-hidden="true">/</span>
            <span>Contacts</span>
          </nav>
          <h1 class="mt-1 text-2xl font-bold">Notification Contacts</h1>
        </div>
      </div>

      <!-- Add contact form -->
      <div class="mt-6 rounded-card border border-border bg-surface p-card">
        <h2 class="text-lg font-semibold">Add Contact</h2>
        <div id="contact-message" class="mt-2 hidden rounded-card p-4 text-sm" role="alert"></div>
        <form id="contact-form" class="mt-4 space-y-4" novalidate>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="field-phone" class="block text-sm font-medium">
                Phone <span class="text-error" aria-hidden="true">*</span>
              </label>
              <input
                id="field-phone"
                type="tel"
                required
                class="mt-1 block w-full rounded-button border border-border bg-surface px-4 py-2.5 text-base placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                placeholder="+1 (555) 123-4567"
              />
            </div>
            <div>
              <label for="field-name" class="block text-sm font-medium">Name</label>
              <input
                id="field-name"
                type="text"
                class="mt-1 block w-full rounded-button border border-border bg-surface px-4 py-2.5 text-base placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                placeholder="Jane Doe"
              />
            </div>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="field-email" class="block text-sm font-medium">Email</label>
              <input
                id="field-email"
                type="email"
                class="mt-1 block w-full rounded-button border border-border bg-surface px-4 py-2.5 text-base placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                placeholder="jane@example.com"
              />
            </div>
            <div>
              <label for="field-locale" class="block text-sm font-medium">Preferred Language</label>
              <select
                id="field-locale"
                class="mt-1 block w-full rounded-button border border-border bg-surface px-4 py-2.5 text-base focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
              >
                <option value="en">English</option>
                <option value="es">Spanish</option>
                <option value="zh-hans">Chinese (Simplified)</option>
                <option value="zh-hant">Chinese (Traditional)</option>
                <option value="ar">Arabic</option>
                <option value="vi">Vietnamese</option>
                <option value="ht">Haitian Creole</option>
                <option value="so">Somali</option>
                <option value="ru">Russian</option>
                <option value="tl">Tagalog</option>
                <option value="hmn">Hmong</option>
                <option value="pt">Portuguese</option>
                <option value="ko">Korean</option>
                <option value="hi">Hindi</option>
                <option value="fr">French</option>
                <option value="am">Amharic</option>
                <option value="km">Khmer</option>
                <option value="ur">Urdu</option>
                <option value="pa">Punjabi</option>
                <option value="sw">Swahili</option>
              </select>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <button
              type="submit"
              id="btn-add"
              class="rounded-button bg-primary px-6 py-2.5 text-sm font-bold text-inverse hover:opacity-90 disabled:opacity-60"
            >
              Add Contact
            </button>
          </div>
        </form>
      </div>

      <!-- Contacts table -->
      <h2 class="mt-8 text-lg font-bold">Contact List</h2>
      <div class="mt-4 overflow-x-auto rounded-card border border-border">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="border-b border-border bg-muted/5">
              <th class="px-4 py-3 font-semibold" scope="col">Phone</th>
              <th class="px-4 py-3 font-semibold" scope="col">Name</th>
              <th class="hidden px-4 py-3 font-semibold sm:table-cell" scope="col">Email</th>
              <th class="hidden px-4 py-3 font-semibold md:table-cell" scope="col">Locale</th>
              <th class="px-4 py-3 text-right font-semibold" scope="col">
                <span class="sr-only">Actions</span>
              </th>
            </tr>
          </thead>
          <tbody id="contacts-tbody">
            <tr>
              <td class="px-4 py-8 text-center text-muted" colspan="5">Loading contacts...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Loading -->
    <div id="admin-loading" class="py-16 text-center">
      <p class="text-muted">Loading...</p>
    </div>
  </div>
</BaseLayout>

<script>
  // @ts-nocheck
  import { createBrowserClient } from '@schoolyard/supabase/browser'
  import { createAdminClient } from '@/lib/admin-client'

  const root = document.querySelector<HTMLElement>('[data-sy-admin]')!
  const url = root.dataset.supabaseUrl ?? ''
  const anon = root.dataset.supabaseAnon ?? ''

  const loadingEl = document.getElementById('admin-loading')!
  const authGate = document.getElementById('admin-auth-gate')!
  const content = document.getElementById('admin-content')!
  const tbody = document.getElementById('contacts-tbody')!
  const form = document.getElementById('contact-form') as HTMLFormElement
  const msgEl = document.getElementById('contact-message')!
  const btnAdd = document.getElementById('btn-add') as HTMLButtonElement

  function showView(id: 'loading' | 'auth' | 'content') {
    loadingEl.classList.toggle('hidden', id !== 'loading')
    authGate.classList.toggle('hidden', id !== 'auth')
    content.classList.toggle('hidden', id !== 'content')
  }

  function showMsg(text: string, type: 'success' | 'error') {
    msgEl.textContent = text
    msgEl.className =
      type === 'success'
        ? 'mt-2 rounded-card p-4 text-sm bg-success/10 border border-success/30'
        : 'mt-2 rounded-card p-4 text-sm bg-error/10 border border-error/30 text-error'
  }

  function escapeHtml(str: string): string {
    const d = document.createElement('div')
    d.textContent = str
    return d.innerHTML
  }

  if (!url || !anon) {
    showView('auth')
  } else {
    const authClient = createBrowserClient({ url, anonKey: anon })

    let admin: ReturnType<typeof createAdminClient>

    async function checkAuth(): Promise<boolean> {
      const {
        data: { session },
      } = await authClient.auth.getSession()
      if (!session) {
        showView('auth')
        return false
      }

      admin = createAdminClient({
        gatewayUrl: url,
        accessToken: session.access_token,
        schoolSlug: root.dataset.schoolSlug ?? '',
      })

      const { data: profile, error } = await admin.getProfile()
      if (error || !profile?.school_id) {
        showView('auth')
        return false
      }

      const allowed = ['editor', 'admin', 'district_admin']
      if (!allowed.includes(profile.role)) {
        showView('auth')
        return false
      }

      return true
    }

    async function loadContacts() {
      const { data: contacts, error } = await admin.list<{
        id: string
        phone: string
        name: string | null
        email: string | null
        locale: string
      }>('notification_contacts')

      if (error || !contacts) {
        tbody.innerHTML = `<tr><td class="px-4 py-8 text-center text-error" colspan="5">Failed to load contacts: ${escapeHtml(error ?? 'Unknown error')}</td></tr>`
        return
      }

      if (contacts.length === 0) {
        tbody.innerHTML = `<tr><td class="px-4 py-8 text-center text-muted" colspan="5">No contacts yet. Add one above.</td></tr>`
        return
      }

      tbody.innerHTML = contacts
        .map(
          (c) => `<tr class="border-b border-border last:border-0 hover:bg-muted/5">
          <td class="px-4 py-3 font-mono text-sm">${escapeHtml(c.phone)}</td>
          <td class="px-4 py-3">${escapeHtml(c.name ?? '--')}</td>
          <td class="hidden px-4 py-3 text-muted sm:table-cell">${escapeHtml(c.email ?? '--')}</td>
          <td class="hidden px-4 py-3 text-muted md:table-cell">${escapeHtml(c.locale ?? 'en')}</td>
          <td class="px-4 py-3 text-right">
            <button type="button" data-delete="${c.id}" data-title="${escapeHtml(c.name ?? c.phone)}" class="text-sm font-semibold text-error hover:underline">Delete</button>
          </td>
        </tr>`,
        )
        .join('')

      // Attach delete handlers
      tbody.querySelectorAll<HTMLButtonElement>('[data-delete]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const id = btn.dataset.delete!
          const title = btn.dataset.title ?? 'this contact'
          if (!confirm(`Delete contact "${title}"? This cannot be undone.`)) return

          btn.disabled = true
          btn.textContent = 'Deleting...'

          const { error: delErr } = await admin.remove('notification_contacts', id)
          if (delErr) {
            alert(`Failed to delete: ${delErr}`)
            btn.disabled = false
            btn.textContent = 'Delete'
          } else {
            loadContacts()
          }
        })
      })
    }

    // Add handler
    form.addEventListener('submit', async (e) => {
      e.preventDefault()

      const phone = (document.getElementById('field-phone') as HTMLInputElement).value.trim()
      const name = (document.getElementById('field-name') as HTMLInputElement).value.trim()
      const email = (document.getElementById('field-email') as HTMLInputElement).value.trim()
      const locale = (document.getElementById('field-locale') as HTMLSelectElement).value

      if (!phone) {
        showMsg('Phone number is required.', 'error')
        return
      }

      btnAdd.disabled = true
      btnAdd.textContent = 'Adding...'

      const { error } = await admin.create('notification_contacts', {
        phone,
        name: name || null,
        email: email || null,
        locale,
      })

      btnAdd.disabled = false
      btnAdd.textContent = 'Add Contact'

      if (error) {
        showMsg(`Failed to add contact: ${error}`, 'error')
        return
      }

      showMsg('Contact added.', 'success')
      form.reset()
      loadContacts()
    })

    async function init() {
      if (await checkAuth()) {
        showView('content')
        loadContacts()
      }
    }

    init()
  }
</script>
