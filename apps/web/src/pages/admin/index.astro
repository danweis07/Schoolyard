---
/**
 * Admin dashboard — auth-gated landing page for the in-app CMS.
 *
 * Shows links to each content section with live row counts. If the user
 * is not signed in, displays a sign-in prompt. The browser Supabase
 * client handles auth checks and data fetching client-side so the page
 * can be statically rendered.
 */
import BaseLayout from '@/layouts/BaseLayout.astro'

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? import.meta.env.SUPABASE_URL ?? ''
const supabaseAnon =
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? import.meta.env.SUPABASE_ANON_KEY ?? ''
---

<BaseLayout title="Admin" description="Content management dashboard">
  <div
    class="mx-auto max-w-3xl px-4 py-8"
    data-sy-admin
    data-supabase-url={supabaseUrl}
    data-supabase-anon={supabaseAnon}
  >
    <!-- Auth gate: shown when not signed in -->
    <div id="admin-auth-gate" class="hidden py-16 text-center">
      <h1 class="text-3xl font-bold">Sign in required</h1>
      <p class="mt-2 text-muted">
        You need to be signed in as an editor or admin to access the CMS.
      </p>
      <a
        href="/sign-in?redirect=/admin"
        class="mt-6 inline-block rounded-button bg-primary px-6 py-3 text-sm font-bold text-inverse hover:opacity-90"
      >
        Sign in
      </a>
    </div>

    <!-- Not authorized: wrong role -->
    <div id="admin-no-role" class="hidden py-16 text-center">
      <h1 class="text-3xl font-bold">Access denied</h1>
      <p class="mt-2 text-muted">
        Your account does not have editor or admin permissions. Contact your school administrator.
      </p>
    </div>

    <!-- Dashboard: shown when authenticated + authorized -->
    <div id="admin-dashboard" class="hidden">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <h1 class="text-3xl font-bold">Content Admin</h1>
          <p class="mt-1 text-sm text-muted">Manage your school's content</p>
        </div>
        <button
          type="button"
          id="admin-signout"
          class="rounded-button border border-border px-4 py-2 text-sm font-semibold hover:bg-muted/10"
        >
          Sign out
        </button>
      </div>

      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        <a
          href="/admin/events/"
          class="group flex items-start gap-4 rounded-card border border-border bg-surface p-card transition-colors hover:bg-muted/5"
        >
          <span
            class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-card bg-primary/10 text-lg"
            aria-hidden="true"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              viewBox="0 0 20 20"
              fill="currentColor"
              ><path
                fill-rule="evenodd"
                d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z"
                clip-rule="evenodd"></path></svg
            >
          </span>
          <div class="min-w-0">
            <span class="font-semibold group-hover:underline">Events</span>
            <p class="mt-0.5 text-xs text-muted">
              <span data-count="events">--</span> events
            </p>
          </div>
        </a>

        <a
          href="/admin/news/"
          class="group flex items-start gap-4 rounded-card border border-border bg-surface p-card transition-colors hover:bg-muted/5"
        >
          <span
            class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-card bg-primary/10 text-lg"
            aria-hidden="true"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              viewBox="0 0 20 20"
              fill="currentColor"
              ><path
                fill-rule="evenodd"
                d="M2 5a2 2 0 012-2h8a2 2 0 012 2v10a2 2 0 002 2H4a2 2 0 01-2-2V5zm3 1h6v4H5V6zm6 6H5v2h6v-2z"
                clip-rule="evenodd"></path><path d="M15 7h1a2 2 0 012 2v5.5a1.5 1.5 0 01-3 0V7z"
              ></path></svg
            >
          </span>
          <div class="min-w-0">
            <span class="font-semibold group-hover:underline">News</span>
            <p class="mt-0.5 text-xs text-muted">
              <span data-count="news">--</span> posts
            </p>
          </div>
        </a>

        <a
          href="/admin/board/"
          class="group flex items-start gap-4 rounded-card border border-border bg-surface p-card transition-colors hover:bg-muted/5"
        >
          <span
            class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-card bg-primary/10 text-lg"
            aria-hidden="true"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              viewBox="0 0 20 20"
              fill="currentColor"
              ><path
                d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"
              ></path></svg
            >
          </span>
          <div class="min-w-0">
            <span class="font-semibold group-hover:underline">Board Members</span>
            <p class="mt-0.5 text-xs text-muted">
              <span data-count="board_members">--</span> members
            </p>
          </div>
        </a>

        <a
          href="#"
          class="group flex items-start gap-4 rounded-card border border-border bg-surface p-card opacity-50"
          aria-disabled="true"
        >
          <span
            class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-card bg-primary/10 text-lg"
            aria-hidden="true"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              viewBox="0 0 20 20"
              fill="currentColor"
              ><path
                d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"
              ></path></svg
            >
          </span>
          <div class="min-w-0">
            <span class="font-semibold">Volunteers</span>
            <p class="mt-0.5 text-xs text-muted">
              <span data-count="volunteer_roles">--</span> roles
            </p>
          </div>
        </a>

        <a
          href="#"
          class="group flex items-start gap-4 rounded-card border border-border bg-surface p-card opacity-50"
          aria-disabled="true"
        >
          <span
            class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-card bg-primary/10 text-lg"
            aria-hidden="true"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              viewBox="0 0 20 20"
              fill="currentColor"
              ><path
                d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z"
              ></path></svg
            >
          </span>
          <div class="min-w-0">
            <span class="font-semibold">Resources</span>
            <p class="mt-0.5 text-xs text-muted">
              <span data-count="resources">--</span> resources
            </p>
          </div>
        </a>

        <a
          href="#"
          class="group flex items-start gap-4 rounded-card border border-border bg-surface p-card opacity-50"
          aria-disabled="true"
        >
          <span
            class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-card bg-primary/10 text-lg"
            aria-hidden="true"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              viewBox="0 0 20 20"
              fill="currentColor"
              ><path
                fill-rule="evenodd"
                d="M18 3a1 1 0 00-1.447-.894L8.763 6H5a3 3 0 000 6h.28l1.771 5.316A1 1 0 008 18h1a1 1 0 001-1v-4.382l6.553 3.276A1 1 0 0018 15V3z"
                clip-rule="evenodd"></path></svg
            >
          </span>
          <div class="min-w-0">
            <span class="font-semibold">Announcements</span>
            <p class="mt-0.5 text-xs text-muted">
              <span data-count="announcements">--</span> announcements
            </p>
          </div>
        </a>
      </div>
    </div>

    <!-- Loading state -->
    <div id="admin-loading" class="py-16 text-center">
      <p class="text-muted">Loading...</p>
    </div>
  </div>
</BaseLayout>

<script>
  // @ts-nocheck — admin scripts use dynamic Supabase queries; typed client infers `never` for placeholder DB types
  import { createBrowserClient } from '@schoolyard/supabase/browser'

  const root = document.querySelector<HTMLElement>('[data-sy-admin]')!
  const url = root.dataset.supabaseUrl ?? ''
  const anon = root.dataset.supabaseAnon ?? ''

  const loadingEl = document.getElementById('admin-loading')!
  const authGate = document.getElementById('admin-auth-gate')!
  const noRole = document.getElementById('admin-no-role')!
  const dashboard = document.getElementById('admin-dashboard')!
  const signoutBtn = document.getElementById('admin-signout')!

  function showView(id: 'loading' | 'auth' | 'norole' | 'dashboard') {
    loadingEl.classList.toggle('hidden', id !== 'loading')
    authGate.classList.toggle('hidden', id !== 'auth')
    noRole.classList.toggle('hidden', id !== 'norole')
    dashboard.classList.toggle('hidden', id !== 'dashboard')
  }

  if (!url || !anon) {
    showView('auth')
  } else {
    const supabase = createBrowserClient({ url, anonKey: anon })

    async function init() {
      const {
        data: { user },
      } = await supabase.auth.getUser()
      if (!user) {
        showView('auth')
        return
      }

      // Resolve profile and school_id
      const { data: profile } = await supabase
        .from('profiles')
        .select('school_id, role')
        .eq('id', user.id)
        .maybeSingle()

      if (!profile || !profile.school_id) {
        showView('norole')
        return
      }

      const allowedRoles = ['editor', 'admin', 'district_admin']
      if (!allowedRoles.includes(profile.role)) {
        showView('norole')
        return
      }

      showView('dashboard')

      // Fetch counts for each content table
      const tables = [
        'events',
        'news',
        'board_members',
        'volunteer_roles',
        'resources',
        'announcements',
      ] as const
      for (const table of tables) {
        const { count } = await supabase
          .from(table)
          .select('id', { count: 'exact', head: true })
          .eq('school_id', profile.school_id)

        const el = document.querySelector<HTMLElement>(`[data-count="${table}"]`)
        if (el) el.textContent = String(count ?? 0)
      }
    }

    signoutBtn.addEventListener('click', async () => {
      await supabase.auth.signOut()
      showView('auth')
    })

    init()
  }
</script>
