---
/**
 * Admin resource editor — create or edit a single community resource.
 *
 * When `?id=<uuid>` is present, loads the existing resource for editing.
 * Otherwise renders a blank form for creating a new resource.
 *
 * All mutations happen client-side via the browser Supabase client.
 * RLS on the resources table enforces that only editors/admins for the
 * matching school_id can insert or update rows.
 */
import BaseLayout from '@/layouts/BaseLayout.astro'

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? import.meta.env.SUPABASE_URL ?? ''
const supabaseAnon =
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? import.meta.env.SUPABASE_ANON_KEY ?? ''
---

<BaseLayout title="Admin - Edit Resource" description="Create or edit a community resource">
  <div
    class="mx-auto max-w-3xl px-4 py-8"
    data-sy-admin
    data-supabase-url={supabaseUrl}
    data-supabase-anon={supabaseAnon}
  >
    <!-- Auth gate -->
    <div id="admin-auth-gate" class="hidden py-16 text-center">
      <h1 class="text-3xl font-bold">Sign in required</h1>
      <p class="mt-2 text-muted">
        You need to be signed in as an editor or admin to edit resources.
      </p>
      <a
        href={`/sign-in?redirect=/admin/resources/edit`}
        class="mt-6 inline-block rounded-button bg-primary px-6 py-3 text-sm font-bold text-inverse hover:opacity-90"
      >
        Sign in
      </a>
    </div>

    <!-- Form -->
    <div id="admin-content" class="hidden">
      <nav class="text-sm text-muted" aria-label="Breadcrumb">
        <a href="/admin/" class="hover:underline">Admin</a>
        <span class="mx-1" aria-hidden="true">/</span>
        <a href="/admin/resources/" class="hover:underline">Resources</a>
        <span class="mx-1" aria-hidden="true">/</span>
        <span id="breadcrumb-action">New</span>
      </nav>
      <h1 class="mt-1 text-2xl font-bold" id="page-title">New Resource</h1>

      <!-- Status messages -->
      <div id="form-message" class="mt-4 hidden rounded-card p-4 text-sm" role="alert"></div>

      <form id="resource-form" class="mt-6 space-y-6" novalidate>
        <!-- Name -->
        <div>
          <label for="field-name" class="block text-sm font-medium"
            >Name <span class="text-error" aria-hidden="true">*</span></label
          >
          <input
            id="field-name"
            type="text"
            required
            class="mt-1 block w-full rounded-button border border-border bg-surface px-4 py-2.5 text-base placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            placeholder="SF-Marin Food Bank"
          />
        </div>

        <!-- Slug -->
        <div>
          <label for="field-slug" class="block text-sm font-medium">Slug</label>
          <input
            id="field-slug"
            type="text"
            class="mt-1 block w-full rounded-button border border-border bg-surface px-4 py-2.5 text-sm font-mono placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            placeholder="sf-marin-food-bank"
          />
          <p class="mt-1 text-xs text-muted">Auto-generated from name. You can edit it.</p>
        </div>

        <!-- Category -->
        <div>
          <label for="field-category" class="block text-sm font-medium"
            >Category <span class="text-error" aria-hidden="true">*</span></label
          >
          <select
            id="field-category"
            required
            class="mt-1 block w-full rounded-button border border-border bg-surface px-4 py-2.5 text-base focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
          >
            <option value="">-- Select category --</option>
            <option value="food">Food</option>
            <option value="health">Health</option>
            <option value="housing">Housing</option>
            <option value="legal">Legal</option>
            <option value="mental-health">Mental Health</option>
            <option value="other">Other</option>
          </select>
        </div>

        <!-- Description -->
        <div>
          <label for="field-description" class="block text-sm font-medium">Description</label>
          <textarea
            id="field-description"
            rows="4"
            class="mt-1 block w-full rounded-button border border-border bg-surface px-4 py-2.5 text-sm font-mono placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            placeholder="Describe the resource..."></textarea>
        </div>

        <!-- Address -->
        <div>
          <label for="field-address" class="block text-sm font-medium">Address</label>
          <input
            id="field-address"
            type="text"
            class="mt-1 block w-full rounded-button border border-border bg-surface px-4 py-2.5 text-base placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            placeholder="900 Pennsylvania Ave, San Francisco, CA 94107"
          />
        </div>

        <!-- Phone / URL row -->
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="field-phone" class="block text-sm font-medium">Phone</label>
            <input
              id="field-phone"
              type="tel"
              class="mt-1 block w-full rounded-button border border-border bg-surface px-4 py-2.5 text-base placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
              placeholder="(415) 555-0123"
            />
          </div>
          <div>
            <label for="field-url" class="block text-sm font-medium">URL</label>
            <input
              id="field-url"
              type="url"
              class="mt-1 block w-full rounded-button border border-border bg-surface px-4 py-2.5 text-base placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
              placeholder="https://example.org"
            />
          </div>
        </div>

        <!-- Languages -->
        <div>
          <label for="field-languages" class="block text-sm font-medium">Languages</label>
          <input
            id="field-languages"
            type="text"
            class="mt-1 block w-full rounded-button border border-border bg-surface px-4 py-2.5 text-base placeholder:text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            placeholder="en, es, zh-hans"
          />
          <p class="mt-1 text-xs text-muted">Comma-separated language codes. Stored as an array.</p>
        </div>

        <!-- Action buttons -->
        <div class="flex flex-wrap items-center gap-3 border-t border-border pt-6">
          <button
            type="submit"
            id="btn-save"
            class="rounded-button bg-primary px-6 py-2.5 text-sm font-bold text-inverse hover:opacity-90 disabled:opacity-60"
          >
            Save Resource
          </button>
          <a
            href="/admin/resources/"
            class="rounded-button border border-border px-6 py-2.5 text-sm font-semibold hover:bg-muted/10"
          >
            Cancel
          </a>
          <button
            type="button"
            id="btn-delete"
            class="ml-auto hidden rounded-button border border-error px-6 py-2.5 text-sm font-semibold text-error hover:bg-error/10 disabled:opacity-60"
          >
            Delete
          </button>
        </div>
      </form>
    </div>

    <!-- Loading -->
    <div id="admin-loading" class="py-16 text-center">
      <p class="text-muted">Loading...</p>
    </div>
  </div>
</BaseLayout>

<script>
  // @ts-nocheck
  import { createBrowserClient } from '@schoolyard/supabase/browser'

  const root = document.querySelector<HTMLElement>('[data-sy-admin]')!
  const url = root.dataset.supabaseUrl ?? ''
  const anon = root.dataset.supabaseAnon ?? ''

  const loadingEl = document.getElementById('admin-loading')!
  const authGate = document.getElementById('admin-auth-gate')!
  const content = document.getElementById('admin-content')!
  const form = document.getElementById('resource-form') as HTMLFormElement
  const msgEl = document.getElementById('form-message')!
  const pageTitle = document.getElementById('page-title')!
  const breadcrumbAction = document.getElementById('breadcrumb-action')!
  const btnSave = document.getElementById('btn-save') as HTMLButtonElement
  const btnDelete = document.getElementById('btn-delete') as HTMLButtonElement

  // Field references
  const f = {
    name: document.getElementById('field-name') as HTMLInputElement,
    slug: document.getElementById('field-slug') as HTMLInputElement,
    category: document.getElementById('field-category') as HTMLSelectElement,
    description: document.getElementById('field-description') as HTMLTextAreaElement,
    address: document.getElementById('field-address') as HTMLInputElement,
    phone: document.getElementById('field-phone') as HTMLInputElement,
    url: document.getElementById('field-url') as HTMLInputElement,
    languages: document.getElementById('field-languages') as HTMLInputElement,
  }

  function showView(id: 'loading' | 'auth' | 'content') {
    loadingEl.classList.toggle('hidden', id !== 'loading')
    authGate.classList.toggle('hidden', id !== 'auth')
    content.classList.toggle('hidden', id !== 'content')
  }

  function showMsg(text: string, type: 'success' | 'error') {
    msgEl.textContent = text
    msgEl.className =
      type === 'success'
        ? 'mt-4 rounded-card p-4 text-sm bg-success/10 border border-success/30'
        : 'mt-4 rounded-card p-4 text-sm bg-error/10 border border-error/30 text-error'
  }

  function slugify(text: string): string {
    return text
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-|-$/g, '')
  }

  // Auto-generate slug from name
  let slugManuallyEdited = false
  f.slug.addEventListener('input', () => {
    slugManuallyEdited = true
  })
  f.name.addEventListener('input', () => {
    if (!slugManuallyEdited) {
      f.slug.value = slugify(f.name.value)
    }
  })

  if (!url || !anon) {
    showView('auth')
  } else {
    const supabase = createBrowserClient({ url, anonKey: anon })
    const params = new URLSearchParams(window.location.search)
    const editId = params.get('id')
    let schoolId = ''

    async function init() {
      const {
        data: { user },
      } = await supabase.auth.getUser()
      if (!user) {
        showView('auth')
        return
      }

      const { data: profile } = await supabase
        .from('profiles')
        .select('school_id, role')
        .eq('id', user.id)
        .maybeSingle()

      const allowed = ['editor', 'admin', 'district_admin']
      if (!profile?.school_id || !allowed.includes(profile.role)) {
        showView('auth')
        return
      }

      schoolId = profile.school_id
      showView('content')

      // If editing, load the resource
      if (editId) {
        pageTitle.textContent = 'Edit Resource'
        breadcrumbAction.textContent = 'Edit'
        btnDelete.classList.remove('hidden')
        slugManuallyEdited = true // don't overwrite existing slug

        const { data: res, error } = await supabase
          .from('resources')
          .select('*')
          .eq('id', editId)
          .eq('school_id', schoolId)
          .maybeSingle()

        if (error || !res) {
          showMsg(error?.message ?? 'Resource not found', 'error')
          return
        }

        f.name.value = res.name ?? ''
        f.slug.value = res.slug ?? ''
        f.category.value = res.category ?? ''
        f.description.value = res.description ?? ''
        f.address.value = res.address ?? ''
        f.phone.value = res.phone ?? ''
        f.url.value = res.url ?? ''
        f.languages.value = Array.isArray(res.languages)
          ? res.languages.join(', ')
          : (res.languages ?? '')
      }
    }

    // Save handler
    form.addEventListener('submit', async (e) => {
      e.preventDefault()

      // Validate required fields
      if (!f.name.value.trim()) {
        showMsg('Name is required.', 'error')
        f.name.focus()
        return
      }
      if (!f.category.value) {
        showMsg('Category is required.', 'error')
        f.category.focus()
        return
      }

      btnSave.disabled = true
      btnSave.textContent = 'Saving...'

      const slug = f.slug.value.trim() || slugify(f.name.value)

      // Parse languages from comma-separated string to array
      const languagesRaw = f.languages.value.trim()
      const languages = languagesRaw
        ? languagesRaw
            .split(',')
            .map((l) => l.trim())
            .filter(Boolean)
        : null

      const row = {
        school_id: schoolId,
        name: f.name.value.trim(),
        slug,
        category: f.category.value,
        description: f.description.value.trim() || null,
        address: f.address.value.trim() || null,
        phone: f.phone.value.trim() || null,
        url: f.url.value.trim() || null,
        languages,
      }

      let result
      if (editId) {
        result = await supabase
          .from('resources')
          .update(row)
          .eq('id', editId)
          .eq('school_id', schoolId)
      } else {
        result = await supabase.from('resources').insert(row).select('id').single()
      }

      btnSave.disabled = false
      btnSave.textContent = 'Save Resource'

      if (result.error) {
        showMsg(`Save failed: ${result.error.message}`, 'error')
        return
      }

      showMsg('Resource saved successfully.', 'success')

      // If creating, redirect to the edit page for the new record
      if (!editId && result.data?.id) {
        setTimeout(() => {
          window.location.href = `/admin/resources/edit?id=${result.data.id}`
        }, 600)
      }
    })

    // Delete handler
    btnDelete.addEventListener('click', async () => {
      if (!editId) return
      if (!confirm('Delete this resource? This cannot be undone.')) return

      btnDelete.disabled = true
      btnDelete.textContent = 'Deleting...'

      const { error } = await supabase
        .from('resources')
        .delete()
        .eq('id', editId)
        .eq('school_id', schoolId)

      if (error) {
        showMsg(`Delete failed: ${error.message}`, 'error')
        btnDelete.disabled = false
        btnDelete.textContent = 'Delete'
        return
      }

      window.location.href = '/admin/resources/'
    })

    init()
  }
</script>
