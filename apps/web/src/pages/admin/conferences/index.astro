---
/**
 * Admin conference windows list — table of all conference windows for
 * the current school with create, edit, and delete actions.
 * All CRUD goes through the gateway edge function.
 */
import BaseLayout from '@/layouts/BaseLayout.astro'
import { siteConfig } from '@/lib/site'

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? import.meta.env.SUPABASE_URL ?? ''
const supabaseAnon =
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? import.meta.env.SUPABASE_ANON_KEY ?? ''
const schoolSlug = siteConfig.school.shortName.toLowerCase().replace(/[^a-z0-9]+/g, '-')
---

<BaseLayout title="Admin - Conferences" description="Manage parent-teacher conference windows">
  <div
    class="mx-auto max-w-5xl px-4 py-8"
    data-sy-admin
    data-supabase-url={supabaseUrl}
    data-supabase-anon={supabaseAnon}
    data-school-slug={schoolSlug}
  >
    <!-- Auth gate -->
    <div id="admin-auth-gate" class="hidden py-16 text-center">
      <h1 class="text-3xl font-bold">Sign in required</h1>
      <p class="mt-2 text-muted">
        You need to be signed in as an editor or admin to manage conferences.
      </p>
      <a
        href="/sign-in?redirect=/admin/conferences/"
        class="mt-6 inline-block rounded-button bg-primary px-6 py-3 text-sm font-bold text-inverse hover:opacity-90"
      >
        Sign in
      </a>
    </div>

    <!-- Main content -->
    <div id="admin-content" class="hidden">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <nav class="text-sm text-muted" aria-label="Breadcrumb">
            <a href="/admin/" class="hover:underline">Admin</a>
            <span class="mx-1" aria-hidden="true">/</span>
            <span>Conferences</span>
          </nav>
          <h1 class="mt-1 text-2xl font-bold">Conference Windows</h1>
        </div>
        <a
          href="/admin/conferences/edit"
          class="rounded-button bg-primary px-4 py-2 text-sm font-bold text-inverse hover:opacity-90"
        >
          New Window
        </a>
      </div>

      <div class="mt-6 overflow-x-auto rounded-card border border-border">
        <table class="w-full text-left text-sm" id="windows-table">
          <thead>
            <tr class="border-b border-border bg-muted/5">
              <th class="px-4 py-3 font-semibold" scope="col">Title</th>
              <th class="hidden px-4 py-3 font-semibold sm:table-cell" scope="col">Starts</th>
              <th class="hidden px-4 py-3 font-semibold md:table-cell" scope="col">Ends</th>
              <th class="px-4 py-3 font-semibold" scope="col">Status</th>
              <th class="px-4 py-3 text-right font-semibold" scope="col">
                <span class="sr-only">Actions</span>
              </th>
            </tr>
          </thead>
          <tbody id="windows-tbody">
            <tr>
              <td class="px-4 py-8 text-center text-muted" colspan="5">Loading conferences...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Loading -->
    <div id="admin-loading" class="py-16 text-center">
      <p class="text-muted">Loading...</p>
    </div>
  </div>
</BaseLayout>

<script>
  // @ts-nocheck
  import { createBrowserClient } from '@schoolyard/supabase/browser'
  import { createAdminClient } from '@/lib/admin-client'

  const root = document.querySelector<HTMLElement>('[data-sy-admin]')!
  const url = root.dataset.supabaseUrl ?? ''
  const anon = root.dataset.supabaseAnon ?? ''

  const loadingEl = document.getElementById('admin-loading')!
  const authGate = document.getElementById('admin-auth-gate')!
  const content = document.getElementById('admin-content')!
  const tbody = document.getElementById('windows-tbody')!

  function showView(id: 'loading' | 'auth' | 'content') {
    loadingEl.classList.toggle('hidden', id !== 'loading')
    authGate.classList.toggle('hidden', id !== 'auth')
    content.classList.toggle('hidden', id !== 'content')
  }

  if (!url || !anon) {
    showView('auth')
  } else {
    const authClient = createBrowserClient({ url, anonKey: anon })

    let admin: ReturnType<typeof createAdminClient>

    async function checkAuth(): Promise<boolean> {
      const {
        data: { session },
      } = await authClient.auth.getSession()
      if (!session) {
        showView('auth')
        return false
      }

      admin = createAdminClient({
        gatewayUrl: url,
        accessToken: session.access_token,
        schoolSlug: root.dataset.schoolSlug ?? '',
      })

      const { data: profile, error } = await admin.getProfile()
      if (error || !profile?.school_id) {
        showView('auth')
        return false
      }

      const allowed = ['editor', 'admin', 'district_admin']
      if (!allowed.includes(profile.role)) {
        showView('auth')
        return false
      }

      return true
    }

    function formatDate(iso: string): string {
      try {
        return new Date(iso).toLocaleDateString(undefined, {
          month: 'short',
          day: 'numeric',
          year: 'numeric',
        })
      } catch {
        return iso
      }
    }

    function escapeHtml(str: string): string {
      const d = document.createElement('div')
      d.textContent = str
      return d.innerHTML
    }

    async function loadWindows() {
      const { data: windows, error } = await admin.list<{
        id: string
        title: string
        slug: string
        starts_on: string
        ends_on: string
        published: boolean
      }>('conference-windows')

      if (error || !windows) {
        tbody.innerHTML = `<tr><td class="px-4 py-8 text-center text-error" colspan="5">Failed to load conferences: ${escapeHtml(error ?? 'Unknown error')}</td></tr>`
        return
      }

      if (windows.length === 0) {
        tbody.innerHTML = `<tr><td class="px-4 py-8 text-center text-muted" colspan="5">No conference windows yet. <a href="/admin/conferences/edit" class="font-semibold underline">Create your first window</a></td></tr>`
        return
      }

      tbody.innerHTML = windows
        .map((w) => {
          const statusBadge = w.published
            ? '<span class="inline-block rounded-button bg-success/15 px-2 py-0.5 text-xs font-medium">Published</span>'
            : '<span class="inline-block rounded-button bg-warning/15 px-2 py-0.5 text-xs font-medium">Draft</span>'

          return `<tr class="border-b border-border last:border-0 hover:bg-muted/5">
          <td class="px-4 py-3">
            <span class="font-medium">${escapeHtml(w.title)}</span>
          </td>
          <td class="hidden px-4 py-3 text-muted sm:table-cell">${formatDate(w.starts_on)}</td>
          <td class="hidden px-4 py-3 text-muted md:table-cell">${formatDate(w.ends_on)}</td>
          <td class="px-4 py-3">${statusBadge}</td>
          <td class="px-4 py-3 text-right">
            <a href="/admin/conferences/slots?window_id=${w.id}" class="text-sm font-semibold hover:underline">Slots</a>
            <a href="/admin/conferences/edit?id=${w.id}" class="ml-3 text-sm font-semibold hover:underline">Edit</a>
            <button type="button" data-delete="${w.id}" data-title="${escapeHtml(w.title)}" class="ml-3 text-sm font-semibold text-error hover:underline">Delete</button>
          </td>
        </tr>`
        })
        .join('')

      // Attach delete handlers
      tbody.querySelectorAll<HTMLButtonElement>('[data-delete]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const id = btn.dataset.delete!
          const title = btn.dataset.title ?? 'this window'
          if (!confirm(`Delete "${title}"? This cannot be undone.`)) return

          btn.disabled = true
          btn.textContent = 'Deleting...'

          const { error: delErr } = await admin.remove('conference-windows', id)
          if (delErr) {
            alert(`Failed to delete: ${delErr}`)
            btn.disabled = false
            btn.textContent = 'Delete'
          } else {
            loadWindows()
          }
        })
      })
    }

    async function init() {
      if (await checkAuth()) {
        showView('content')
        loadWindows()
      }
    }

    init()
  }
</script>
