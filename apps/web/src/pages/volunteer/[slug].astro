---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { siteConfig } from '@/lib/site'
import { isModuleEnabled } from '@schoolyard/config'
import { getCollection } from 'astro:content'
import { useTranslate, getLocaleFromUrl, localizedPath } from '@/i18n/index'

export async function getStaticPaths() {
  const roles = await getCollection('volunteers')
  return roles.map((role) => ({
    params: { slug: role.slug },
    props: { role },
  }))
}

const { role } = Astro.props
const { Content } = await role.render()

if (!isModuleEnabled(siteConfig, 'volunteer')) {
  return Astro.redirect('/404')
}

const locale = getLocaleFromUrl(Astro.url)
const t = useTranslate(locale)
---

<BaseLayout title={role.data.title} description={role.data.description}>
  <article class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-4xl font-bold">{role.data.title}</h1>
    <p class="mt-4 text-lg">{role.data.description}</p>
    <p class="mt-2 text-sm text-muted">
      <strong>{t('volunteer.commitment')}:</strong> {role.data.commitment}
    </p>

    <div class="prose mt-8 max-w-none text-base">
      <Content />
    </div>

    {
      !role.data.filled && (
        <form
          name="volunteer-signup"
          method="POST"
          data-netlify="true"
          class="mt-12 rounded-card border border-border bg-surface p-card"
        >
          <input type="hidden" name="form-name" value="volunteer-signup" />
          <input type="hidden" name="role" value={role.data.title} />

          <h2 class="text-xl font-bold">{t('volunteer.signUp')}</h2>

          <label class="mt-4 block">
            <span class="text-sm font-semibold">{t('contact.form.name')}</span>
            <input
              type="text"
              name="name"
              required
              class="mt-1 block w-full rounded-button border border-border bg-surface px-3 py-2"
            />
          </label>

          <label class="mt-4 block">
            <span class="text-sm font-semibold">{t('contact.form.email')}</span>
            <input
              type="email"
              name="email"
              required
              class="mt-1 block w-full rounded-button border border-border bg-surface px-3 py-2"
            />
          </label>

          <label class="mt-4 block">
            <span class="text-sm font-semibold">{t('contact.form.message')}</span>
            <textarea
              name="message"
              rows="3"
              class="mt-1 block w-full rounded-button border border-border bg-surface px-3 py-2"
            ></textarea>
          </label>

          <button
            type="submit"
            class="mt-6 rounded-button bg-primary px-6 py-2.5 font-semibold text-inverse hover:opacity-90"
          >
            {t('volunteer.signUp')}
          </button>
        </form>
      )
    }

    <p class="mt-12">
      <a href={localizedPath('/volunteer', locale)} class="text-primary">
        ← {t('common.back')} {t('volunteer.title').toLowerCase()}
      </a>
    </p>
  </article>
</BaseLayout>
