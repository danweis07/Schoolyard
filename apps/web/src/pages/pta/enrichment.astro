---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { siteConfig } from '@/lib/site'
import { isModuleEnabled } from '@schoolyard/config'
import { getCollection } from 'astro:content'
import { useTranslate, getLocaleFromUrl, localizedPath } from '@/i18n/index'

if (!isModuleEnabled(siteConfig, 'pta')) {
  return Astro.redirect('/404')
}

const locale = getLocaleFromUrl(Astro.url)
const t = useTranslate(locale)

const programs = (await getCollection('programs')).sort((a, b) => a.data.order - b.data.order)

/**
 * Parse "$30,000/year" to 30000 so we can total the annual cost.
 * Programs with non-parseable funding strings are ignored in the total.
 */
function parseFunding(value: string | undefined): number {
  if (!value) return 0
  const match = value.match(/\$?([\d,]+)/)
  if (!match) return 0
  return Number(match[1].replace(/,/g, '')) || 0
}

const totalBudget = programs.reduce((sum, p) => sum + parseFunding(p.data.funding), 0)
const currencyFormatter = new Intl.NumberFormat(locale, {
  style: 'currency',
  currency: 'USD',
  maximumFractionDigits: 0,
})
---

<BaseLayout title={t('pta.enrichment')}>
  <section class="mx-auto max-w-4xl px-4 py-12">
    <h1 class="text-4xl font-bold">{t('pta.enrichment')}</h1>
    <p class="mt-4 text-lg text-muted">{t('pta.enrichmentDescription')}</p>
    <p class="mt-2 text-sm font-medium text-primary">{t('pta.enrichmentFundedBy')}</p>

    <div class="mt-10 grid gap-6">
      {
        programs.map((program) => (
          <article class="rounded-card border border-border bg-surface p-card shadow-sm">
            <h2 class="text-xl font-bold">{program.data.name}</h2>
            <p class="mt-3 text-base">{program.data.description}</p>
            <div class="mt-4 grid gap-2 text-sm text-muted sm:grid-cols-3">
              <div>
                <span class="font-semibold">{t('pta.enrichmentGrades')}:</span>{' '}
                {program.data.grades}
              </div>
              <div>
                <span class="font-semibold">{t('pta.enrichmentSchedule')}:</span>{' '}
                {program.data.schedule}
              </div>
              {program.data.funding && (
                <div>
                  <span class="font-semibold">{t('pta.enrichmentCost')}:</span>{' '}
                  {program.data.funding}
                </div>
              )}
            </div>
          </article>
        ))
      }
    </div>

    {
      totalBudget > 0 && (
        <div class="mt-10 rounded-card border border-accent/20 bg-accent/5 p-card">
          <h2 class="text-xl font-bold">
            {t('pta.enrichmentTotalHeading')}: {currencyFormatter.format(totalBudget)}
          </h2>
          <p class="mt-2 text-base">{t('pta.enrichmentTotalBody')}</p>
          {isModuleEnabled(siteConfig, 'fundraising') && siteConfig.fundraising.donateUrl && (
            <a
              href={localizedPath('/donate', locale)}
              class="mt-4 inline-block rounded-button bg-primary px-6 py-3 font-semibold text-inverse no-underline hover:opacity-90"
            >
              {t('fundraising.donate')}
            </a>
          )}
        </div>
      )
    }
  </section>
</BaseLayout>
