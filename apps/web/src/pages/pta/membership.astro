---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { siteConfig } from '@/lib/site'
import { isModuleEnabled } from '@schoolyard/config'
import { useTranslate, getLocaleFromUrl } from '@/i18n/index'

if (!isModuleEnabled(siteConfig, 'pta')) {
  return Astro.redirect('/404')
}

const locale = getLocaleFromUrl(Astro.url)
const t = useTranslate(locale)
---

<BaseLayout title={t('pta.membership')}>
  <section class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-4xl font-bold">{t('pta.membership')}</h1>
    {
      siteConfig.pta.membershipFee > 0 && (
        <p class="mt-4 text-2xl font-semibold text-primary">
          {t('pta.membershipFee', { fee: siteConfig.pta.membershipFee })}
        </p>
      )
    }
    <p class="mt-6 text-lg">{t('pta.overview')}</p>

    {
      siteConfig.pta.membershipUrl && (
        <a
          href={siteConfig.pta.membershipUrl}
          class="mt-8 inline-block rounded-button bg-primary px-6 py-3 font-semibold text-inverse no-underline hover:opacity-90"
        >
          {t('pta.joinNow')}
        </a>
      )
    }
  </section>
</BaseLayout>
