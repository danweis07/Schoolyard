---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { siteConfig } from '@/lib/site'
import { isModuleEnabled } from '@schoolyard/config'
import { useTranslate, getLocaleFromUrl, localizedPath } from '@/i18n/index'

if (!isModuleEnabled(siteConfig, 'pta')) {
  return Astro.redirect('/404')
}

const locale = getLocaleFromUrl(Astro.url)
const t = useTranslate(locale)
---

<BaseLayout title={t('pta.title')}>
  <section class="mx-auto max-w-4xl px-4 py-12">
    <h1 class="text-4xl font-bold">{siteConfig.pta.name || t('pta.title')}</h1>
    <p class="mt-4 text-lg text-muted">{t('pta.overview')}</p>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <a
        href={localizedPath('/pta/board', locale)}
        class="rounded-card border border-border bg-surface p-card no-underline shadow-sm transition hover:shadow-md"
      >
        <h2 class="text-xl font-bold text-base">{t('pta.board')}</h2>
        <p class="mt-2 text-sm text-muted">{t('pta.boardDescription')}</p>
      </a>
      <a
        href={localizedPath('/pta/membership', locale)}
        class="rounded-card border border-border bg-surface p-card no-underline shadow-sm transition hover:shadow-md"
      >
        <h2 class="text-xl font-bold text-base">{t('pta.membership')}</h2>
        {
          siteConfig.pta.membershipFee > 0 && (
            <p class="mt-2 text-sm text-muted">
              {t('pta.membershipFee', { fee: siteConfig.pta.membershipFee })}
            </p>
          )
        }
      </a>
      <a
        href={localizedPath('/pta/meetings', locale)}
        class="rounded-card border border-border bg-surface p-card no-underline shadow-sm transition hover:shadow-md"
      >
        <h2 class="text-xl font-bold text-base">{t('pta.meetings')}</h2>
        <p class="mt-2 text-sm text-muted">{t('pta.meetingsDescription')}</p>
      </a>
      <a
        href={localizedPath('/pta/committees', locale)}
        class="rounded-card border border-border bg-surface p-card no-underline shadow-sm transition hover:shadow-md"
      >
        <h2 class="text-xl font-bold text-base">{t('pta.committees')}</h2>
        <p class="mt-2 text-sm text-muted">{t('pta.committeesDescription')}</p>
      </a>
      <a
        href={localizedPath('/pta/newsletters', locale)}
        class="rounded-card border border-border bg-surface p-card no-underline shadow-sm transition hover:shadow-md"
      >
        <h2 class="text-xl font-bold text-base">{t('pta.newsletters')}</h2>
        <p class="mt-2 text-sm text-muted">{t('pta.newslettersDescription')}</p>
      </a>
      <a
        href={localizedPath('/pta/enrichment', locale)}
        class="rounded-card border border-border bg-surface p-card no-underline shadow-sm transition hover:shadow-md"
      >
        <h2 class="text-xl font-bold text-base">{t('pta.enrichment')}</h2>
        <p class="mt-2 text-sm text-muted">{t('pta.enrichmentDescription')}</p>
      </a>
    </div>
  </section>
</BaseLayout>
