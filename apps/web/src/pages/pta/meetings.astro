---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { siteConfig } from '@/lib/site'
import { isModuleEnabled } from '@schoolyard/config'
import { useTranslate, getLocaleFromUrl } from '@/i18n/index'

if (!isModuleEnabled(siteConfig, 'pta')) {
  return Astro.redirect('/404')
}

const locale = getLocaleFromUrl(Astro.url)
const t = useTranslate(locale)
---

<BaseLayout title={t('pta.meetings')}>
  <section class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-4xl font-bold">{t('pta.meetings')}</h1>
    <p class="mt-4 text-lg text-muted">{t('pta.meetingsDescription')}</p>

    <div class="mt-8 rounded-card border border-border bg-surface p-card">
      <p class="text-base">
        Meetings are held the second Tuesday of each month, 6:30 PM in the Longfellow library.
      </p>
      <p class="mt-2 text-base">
        Childcare is provided. Spanish translation available on request — contact our communications chair at least 48 hours in advance.
      </p>
    </div>

    <p class="mt-8 text-sm text-muted">
      Past meeting minutes are archived and available on request from the PTA secretary.
    </p>
  </section>
</BaseLayout>
