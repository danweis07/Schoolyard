---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { siteConfig } from '@/lib/site'
import { isModuleEnabled } from '@schoolyard/config'
import { getCollection } from 'astro:content'
import { useTranslate, getLocaleFromUrl } from '@/i18n/index'

if (!isModuleEnabled(siteConfig, 'community')) {
  return Astro.redirect('/404')
}

const locale = getLocaleFromUrl(Astro.url)
const t = useTranslate(locale)

const now = new Date()
const listings = (await getCollection('communityListings'))
  .filter((l) => !l.data.expiresDate || l.data.expiresDate >= now)
  .sort((a, b) => a.data.order - b.data.order)

const categories = [
  'classified',
  'carpool',
  'skill-share',
  'business',
  'new-family',
  'other',
] as const
type Category = (typeof categories)[number]

const byCategory: Record<Category, typeof listings> = {
  classified: [],
  carpool: [],
  'skill-share': [],
  business: [],
  'new-family': [],
  other: [],
}
for (const listing of listings) {
  byCategory[listing.data.category].push(listing)
}
---

<BaseLayout title={t('community.title')} description={t('community.description')}>
  <section class="mx-auto max-w-4xl px-4 py-12">
    <h1 class="text-4xl font-bold">{t('community.title')}</h1>
    <p class="mt-2 text-lg text-muted">{t('community.description')}</p>

    {
      listings.length === 0 ? (
        <p class="mt-8 text-muted">{t('community.noListings')}</p>
      ) : (
        <div class="mt-10 space-y-10">
          {categories.map((cat) =>
            byCategory[cat].length > 0 ? (
              <div>
                <h2 class="text-2xl font-bold">{t(`community.categories.${cat}`)}</h2>
                <div class="mt-4 grid gap-4 md:grid-cols-2">
                  {byCategory[cat].map((listing) => (
                    <article class="rounded-card border border-border bg-surface p-card shadow-sm">
                      <h3 class="text-lg font-bold">{listing.data.title}</h3>
                      <p class="mt-2 text-sm">{listing.data.description}</p>
                      <dl class="mt-3 text-xs text-muted">
                        {listing.data.neighborhood && (
                          <div>
                            <dt class="inline font-semibold">{t('community.neighborhood')}:</dt>{' '}
                            <dd class="inline">{listing.data.neighborhood}</dd>
                          </div>
                        )}
                        {listing.data.contact && (
                          <div>
                            <dt class="inline font-semibold">{t('community.contact')}:</dt>{' '}
                            <dd class="inline">{listing.data.contact}</dd>
                          </div>
                        )}
                      </dl>
                    </article>
                  ))}
                </div>
              </div>
            ) : null,
          )}
        </div>
      )
    }
  </section>
</BaseLayout>
