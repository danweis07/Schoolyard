---
import BaseLayout from '@/layouts/BaseLayout.astro'
import NewsCard from '@/modules/news/components/NewsCard.astro'
import { siteConfig } from '@/lib/site'
import { isModuleEnabled } from '@schoolyard/config'
import { getCollection } from 'astro:content'
import { useTranslate, getLocaleFromUrl } from '@/i18n/index'

if (!isModuleEnabled(siteConfig, 'news')) {
  return Astro.redirect('/404')
}

const locale = getLocaleFromUrl(Astro.url)
const t = useTranslate(locale)

const posts = (await getCollection('news')).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
)
---

<BaseLayout title={t('news.title')} description={t('news.description')}>
  <section class="mx-auto max-w-6xl px-4 py-12">
    <h1 class="text-4xl font-bold">{t('news.title')}</h1>
    <p class="mt-2 text-lg text-muted">{t('news.description')}</p>

    {
      posts.length === 0 ? (
        <p class="mt-8 text-muted">{t('news.noPosts')}</p>
      ) : (
        <div class="mt-8 grid gap-6 md:grid-cols-2">
          {posts.map((post) => (
            <NewsCard post={post} locale={locale} />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
