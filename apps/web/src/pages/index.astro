---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Hero from '@/components/Hero.astro'
import EventCard from '@/modules/events/components/EventCard.astro'
import NewsCard from '@/modules/news/components/NewsCard.astro'
import DonationProgress from '@/modules/fundraising/components/DonationProgress.astro'
import { siteConfig } from '@/lib/site'
import { isModuleEnabled } from '@schoolyard/config'
import { getCollection } from 'astro:content'
import { useTranslate, getLocaleFromUrl, localizedPath } from '@/i18n/index'

const locale = getLocaleFromUrl(Astro.url)
const t = useTranslate(locale)

const eventsEnabled = isModuleEnabled(siteConfig, 'events')
const newsEnabled = isModuleEnabled(siteConfig, 'news')
const fundraisingEnabled = isModuleEnabled(siteConfig, 'fundraising')

const now = new Date()

const upcomingEvents = eventsEnabled
  ? (await getCollection('events'))
      .filter((e) => !e.data.cancelled && e.data.date >= now)
      .sort((a, b) => a.data.date.getTime() - b.data.date.getTime())
      .slice(0, 3)
  : []

const recentNews = newsEnabled
  ? (await getCollection('news'))
      .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
      .slice(0, 4)
  : []
---

<BaseLayout>
  <Hero title={siteConfig.school.name} tagline={siteConfig.school.tagline} />

  {
    eventsEnabled && upcomingEvents.length > 0 && (
      <section class="mx-auto max-w-6xl px-4 py-12">
        <div class="flex items-baseline justify-between">
          <h2 class="text-3xl font-bold">{t('home.upcomingEventsTitle')}</h2>
          <a href={localizedPath('/events', locale)} class="text-sm font-semibold text-primary">
            {t('common.viewAll')} →
          </a>
        </div>
        <div class="mt-6 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {upcomingEvents.map((event) => (
            <EventCard event={event} locale={locale} />
          ))}
        </div>
      </section>
    )
  }

  {
    newsEnabled && recentNews.length > 0 && (
      <section class="mx-auto max-w-6xl px-4 py-12">
        <div class="flex items-baseline justify-between">
          <h2 class="text-3xl font-bold">{t('home.latestNewsTitle')}</h2>
          <a href={localizedPath('/news', locale)} class="text-sm font-semibold text-primary">
            {t('common.viewAll')} →
          </a>
        </div>
        <div class="mt-6 grid gap-6 md:grid-cols-2">
          {recentNews.map((post) => (
            <NewsCard post={post} locale={locale} />
          ))}
        </div>
      </section>
    )
  }

  {
    fundraisingEnabled && siteConfig.fundraising.annualGoal > 0 && (
      <section class="bg-muted py-12">
        <div class="mx-auto max-w-3xl px-4">
          <h2 class="text-3xl font-bold">{t('home.donateBannerTitle')}</h2>
          <div class="mt-6">
            <DonationProgress
              raised={siteConfig.fundraising.currentRaised}
              goal={siteConfig.fundraising.annualGoal}
              label={siteConfig.fundraising.goalLabel}
              locale={locale}
            />
          </div>
          {siteConfig.fundraising.donateUrl && (
            <a
              href={localizedPath('/donate', locale)}
              class="mt-6 inline-block rounded-button bg-primary px-6 py-3 font-semibold text-inverse no-underline hover:opacity-90"
            >
              {t('home.donateBannerCta')}
            </a>
          )}
        </div>
      </section>
    )
  }
</BaseLayout>
