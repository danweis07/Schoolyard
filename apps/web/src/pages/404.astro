---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { useTranslate, getLocaleFromUrl, localizedPath } from '@/i18n/index'

const locale = getLocaleFromUrl(Astro.url)
const t = useTranslate(locale)
---

<BaseLayout title={t('errors.notFound')}>
  <section class="mx-auto max-w-3xl px-4 py-section text-center">
    <p class="text-6xl font-bold text-primary">404</p>
    <h1 class="mt-4 text-3xl font-bold">{t('errors.notFound')}</h1>
    <p class="mt-2 text-lg text-muted">{t('errors.notFoundDescription')}</p>
    <a
      href={localizedPath('/', locale)}
      class="mt-8 inline-block rounded-button bg-primary px-6 py-3 font-semibold text-inverse no-underline hover:opacity-90"
    >
      {t('errors.goHome')}
    </a>
  </section>
</BaseLayout>
