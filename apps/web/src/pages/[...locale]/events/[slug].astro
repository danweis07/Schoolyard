---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { siteConfig } from '@/lib/site'
import { isModuleEnabled } from '@schoolyard/config'
import { getCollection } from 'astro:content'
import {
  useTranslate,
  getLocaleFromUrl,
  localizedPath,
  supportedLocales,
  defaultLocale,
} from '@/i18n/index'

export async function getStaticPaths() {
  const events = await getCollection('events')
  return events.flatMap((event) =>
    supportedLocales.map((code) => ({
      params: {
        locale: code === defaultLocale ? undefined : code,
        slug: event.slug,
      },
      props: { event },
    })),
  )
}

const { event } = Astro.props
const { Content } = await event.render()

if (!isModuleEnabled(siteConfig, 'events')) {
  return Astro.redirect('/404')
}

const locale = getLocaleFromUrl(Astro.url)
const t = useTranslate(locale)
const dateFormatter = new Intl.DateTimeFormat(locale, {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
  year: 'numeric',
})
---

<BaseLayout title={event.data.title} description={event.data.description}>
  <article class="mx-auto max-w-3xl px-4 py-12">
    <p class="text-sm font-semibold uppercase tracking-wide text-primary">
      {dateFormatter.format(event.data.date)}
      {event.data.time && ` · ${event.data.time}`}
    </p>
    <h1 class="mt-2 text-4xl font-bold">{event.data.title}</h1>
    {
      event.data.location && (
        <p class="mt-2 text-lg text-muted">
          <strong>{t('events.location')}:</strong> {event.data.location}
        </p>
      )
    }

    <p class="mt-6 text-lg">{event.data.description}</p>

    <div class="prose mt-8 max-w-none text-base">
      <Content />
    </div>

    {
      event.data.registrationUrl && (
        <a
          href={event.data.registrationUrl}
          class="mt-8 inline-block rounded-button bg-primary px-6 py-3 font-semibold text-inverse no-underline hover:opacity-90"
        >
          {t('events.rsvp')}
        </a>
      )
    }

    <p class="mt-12">
      <a href={localizedPath('/events', locale)} class="text-primary">
        ← {t('common.back')}
        {t('events.title').toLowerCase()}
      </a>
    </p>
  </article>
</BaseLayout>
