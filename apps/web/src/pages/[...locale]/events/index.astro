---
import BaseLayout from '@/layouts/BaseLayout.astro'
import EventCard from '@/modules/events/components/EventCard.astro'
import CalendarGrid from '@/modules/events/components/CalendarGrid.astro'
import { siteConfig } from '@/lib/site'
import { isModuleEnabled } from '@schoolyard/config'
import { getCollection } from 'astro:content'
import { useTranslate, getLocaleFromUrl, localeStaticPaths } from '@/i18n/index'

export const getStaticPaths = localeStaticPaths

if (!isModuleEnabled(siteConfig, 'events')) {
  return Astro.redirect('/404')
}

const locale = getLocaleFromUrl(Astro.url)
const t = useTranslate(locale)
const now = new Date()

const view = Astro.url.searchParams.get('view') ?? 'list'
const monthParam = Astro.url.searchParams.get('month')
const currentMonth = monthParam
  ? new Date(`${monthParam}-01T00:00:00`)
  : new Date(now.getFullYear(), now.getMonth(), 1)

const allEvents = await getCollection('events')
const upcoming = allEvents
  .filter((e) => !e.data.cancelled && e.data.date >= now)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime())
const past = allEvents
  .filter((e) => e.data.date < now)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
---

<BaseLayout title={t('events.title')} description={t('events.description')}>
  <section class="mx-auto max-w-6xl px-4 py-12">
    <h1 class="text-4xl font-bold">{t('events.title')}</h1>
    <p class="mt-2 text-lg text-muted">{t('events.description')}</p>

    {/* View toggle */}
    <div class="mt-6 flex items-center gap-2">
      <a
        href="?view=list"
        class:list={[
          'rounded-button px-4 py-2 text-sm font-medium transition',
          view === 'list'
            ? 'bg-primary text-inverse'
            : 'border border-border text-muted hover:bg-primary/10',
        ]}
        aria-current={view === 'list' ? 'page' : undefined}
      >
        {t('events.listView')}
      </a>
      <a
        href="?view=calendar"
        class:list={[
          'rounded-button px-4 py-2 text-sm font-medium transition',
          view === 'calendar'
            ? 'bg-primary text-inverse'
            : 'border border-border text-muted hover:bg-primary/10',
        ]}
        aria-current={view === 'calendar' ? 'page' : undefined}
      >
        {t('events.calendarView')}
      </a>
    </div>

    {
      view === 'calendar' ? (
        <div class="mt-8">
          <CalendarGrid
            events={allEvents}
            locale={locale}
            currentMonth={currentMonth}
          />
        </div>
      ) : (
        <>
          <h2 class="mt-12 text-2xl font-bold">{t('events.upcoming')}</h2>
          {upcoming.length === 0 ? (
            <p class="mt-4 text-muted">{t('events.noEvents')}</p>
          ) : (
            <div class="mt-6 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
              {upcoming.map((event) => (
                <EventCard event={event} locale={locale} />
              ))}
            </div>
          )}

          {past.length > 0 && (
            <>
              <h2 class="mt-12 text-2xl font-bold">{t('events.past')}</h2>
              <div class="mt-6 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
                {past.slice(0, 6).map((event) => (
                  <EventCard event={event} locale={locale} />
                ))}
              </div>
            </>
          )}
        </>
      )
    }
  </section>
</BaseLayout>
