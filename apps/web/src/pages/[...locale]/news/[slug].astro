---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { siteConfig } from '@/lib/site'
import { isModuleEnabled } from '@schoolyard/config'
import { getCollection } from 'astro:content'
import {
  useTranslate,
  getLocaleFromUrl,
  localizedPath,
  supportedLocales,
  defaultLocale,
} from '@/i18n/index'

export async function getStaticPaths() {
  const posts = await getCollection('news')
  return posts.flatMap((post) =>
    supportedLocales.map((code) => ({
      params: {
        locale: code === defaultLocale ? undefined : code,
        slug: post.slug,
      },
      props: { post },
    })),
  )
}

const { post } = Astro.props
const { Content } = await post.render()

if (!isModuleEnabled(siteConfig, 'news')) {
  return Astro.redirect('/404')
}

const locale = getLocaleFromUrl(Astro.url)
const t = useTranslate(locale)
const dateFormatter = new Intl.DateTimeFormat(locale, {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
})
---

<BaseLayout title={post.data.title} description={post.data.summary}>
  <article class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-4xl font-bold">{post.data.title}</h1>
    <p class="mt-2 text-sm text-muted">
      {dateFormatter.format(post.data.publishDate)}
      {post.data.author && ` · ${t('news.by')} ${post.data.author}`}
    </p>
    <p class="mt-4 text-lg text-muted">{post.data.summary}</p>

    <div class="prose mt-8 max-w-none text-base">
      <Content />
    </div>

    {
      post.data.tags.length > 0 && (
        <ul class="mt-8 flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <li class="rounded-button bg-muted px-2 py-1 text-xs text-muted">#{tag}</li>
          ))}
        </ul>
      )
    }

    <p class="mt-12">
      <a href={localizedPath('/news', locale)} class="text-primary">
        ← {t('common.back')}
        {t('news.title').toLowerCase()}
      </a>
    </p>
  </article>
</BaseLayout>
