---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { siteConfig } from '@/lib/site'
import { isModuleEnabled } from '@schoolyard/config'
import { getCollection } from 'astro:content'
import { useTranslate, getLocaleFromUrl, localizedPath, localeStaticPaths } from '@/i18n/index'

export const getStaticPaths = localeStaticPaths

if (!isModuleEnabled(siteConfig, 'classroom')) {
  return Astro.redirect('/404')
}

const locale = getLocaleFromUrl(Astro.url)
const t = useTranslate(locale)

const teachers = (await getCollection('classroomTeachers')).sort(
  (a, b) => a.data.order - b.data.order,
)
---

<BaseLayout title={t('classroom.title')} description={t('classroom.description')}>
  <section class="mx-auto max-w-6xl px-4 py-12">
    <h1 class="text-4xl font-bold">{t('classroom.title')}</h1>
    <p class="mt-2 text-lg text-muted">{t('classroom.description')}</p>

    <h2 class="mt-12 text-2xl font-bold">{t('classroom.teachers')}</h2>
    {
      teachers.length === 0 ? (
        <p class="mt-4 text-muted">{t('classroom.noTeachers')}</p>
      ) : (
        <div class="mt-6 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {teachers.map((teacher) => (
            <a
              href={localizedPath(`/classroom/${teacher.slug}`, locale)}
              class="rounded-card border border-border bg-surface p-card no-underline shadow-sm transition hover:shadow-md"
            >
              <h3 class="text-xl font-bold">{teacher.data.name}</h3>
              <p class="mt-1 text-sm text-muted">
                {t('classroom.grade')}: {teacher.data.grade}
                {teacher.data.subject && ` · ${teacher.data.subject}`}
              </p>
              {teacher.data.wishlist.length > 0 && (
                <p class="mt-3 text-xs text-muted">
                  {teacher.data.wishlist.length} {t('classroom.wishlist').toLowerCase()} items
                </p>
              )}
            </a>
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
