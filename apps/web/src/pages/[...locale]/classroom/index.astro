---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { siteConfig } from '@/lib/site'
import { isModuleEnabled } from '@schoolyard/config'
import { getCollection } from 'astro:content'
import { useTranslate, getLocaleFromUrl, localeStaticPaths } from '@/i18n/index'
import TeacherCard from '@/modules/classroom/components/TeacherCard.astro'

export const getStaticPaths = localeStaticPaths

if (!isModuleEnabled(siteConfig, 'classroom')) {
  return Astro.redirect('/404')
}

const locale = getLocaleFromUrl(Astro.url)
const t = useTranslate(locale)

const teachers = (await getCollection('classroomTeachers')).sort(
  (a, b) => a.data.order - b.data.order,
)

// Group teachers by grade for a cleaner reading experience.
const byGrade = new Map<string, typeof teachers>()
for (const teacher of teachers) {
  const list = byGrade.get(teacher.data.grade) ?? []
  list.push(teacher)
  byGrade.set(teacher.data.grade, list)
}
const grades = Array.from(byGrade.keys())
---

<BaseLayout title={t('classroom.title')} description={t('classroom.description')}>
  <section class="mx-auto max-w-6xl px-4 py-12">
    <h1 class="text-4xl font-bold">{t('classroom.title')}</h1>
    <p class="mt-2 text-lg text-muted">{t('classroom.description')}</p>

    <h2 class="mt-12 text-2xl font-bold">{t('classroom.teachers')}</h2>
    {
      teachers.length === 0 ? (
        <p class="mt-4 text-muted">{t('classroom.noTeachers')}</p>
      ) : (
        <div class="mt-6 space-y-10">
          {grades.map((grade) => (
            <div>
              <h3 class="text-lg font-semibold text-muted">
                {t('classroom.grade')}: {grade}
              </h3>
              <div class="mt-3 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
                {byGrade.get(grade)!.map((teacher) => (
                  <TeacherCard teacher={teacher} locale={locale} />
                ))}
              </div>
            </div>
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
