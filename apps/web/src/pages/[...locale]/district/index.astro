---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { siteConfig } from '@/lib/site'
import { isModuleEnabled, isDistrictMode, getTenantSlugs, findTenant } from '@schoolyard/config'
import { useTranslate, getLocaleFromUrl, localeStaticPaths } from '@/i18n/index'
import DistrictHeader from '@/modules/district/components/DistrictHeader.astro'
import SchoolCard from '@/modules/district/components/SchoolCard.astro'

export const getStaticPaths = localeStaticPaths

if (!isModuleEnabled(siteConfig, 'district')) {
  return Astro.redirect('/404')
}

const locale = getLocaleFromUrl(Astro.url)
const t = useTranslate(locale)

const districtMode = isDistrictMode(siteConfig)
const slugs = getTenantSlugs(siteConfig)
const schools = slugs
  .map((slug) => findTenant(siteConfig, slug))
  .filter((s): s is NonNullable<typeof s> => s !== undefined)

const districtName = siteConfig.district?.name ?? siteConfig.school.district ?? t('district.title')
---

<BaseLayout title={t('district.title')} description={t('district.description')}>
  <section class="mx-auto max-w-4xl px-4 py-12">
    <DistrictHeader name={districtName} locale={locale} schoolCount={schools.length} />

    <h2 class="mt-12 text-2xl font-bold">{t('district.schools')}</h2>
    {
      !districtMode || schools.length === 0 ? (
        <p class="mt-4 text-muted">{t('district.noSchools')}</p>
      ) : (
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          {schools.map((school) => (
            <SchoolCard school={school} locale={locale} />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
