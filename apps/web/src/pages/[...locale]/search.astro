---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { useTranslate, getLocaleFromUrl, localeStaticPaths } from '@/i18n/index'

/**
 * Static search page powered by Pagefind.
 * Pagefind builds its index from the generated `dist/` output at the end
 * of `pnpm --filter web build` (see package.json). No server required.
 */

export const getStaticPaths = localeStaticPaths

const locale = getLocaleFromUrl(Astro.url)
const t = useTranslate(locale)
---

<BaseLayout title={t('common.search')} description={t('common.search')}>
  <section class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-4xl font-bold">{t('common.search')}</h1>

    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <div id="search" class="mt-8"></div>

    <script is:inline src="/pagefind/pagefind-ui.js"></script>
    <script is:inline define:vars={{ locale, searchPlaceholder: t('common.searchPlaceholder') }}>
      window.addEventListener('DOMContentLoaded', () => {
        // @ts-ignore — PagefindUI is injected by the script tag above
        new PagefindUI({
          element: '#search',
          showSubResults: true,
          translations: {
            placeholder: searchPlaceholder,
          },
          language: locale,
        })
      })
    </script>

    <noscript>
      <p class="mt-4 text-muted">
        Search requires JavaScript. You can still browse the site without it.
      </p>
    </noscript>
  </section>
</BaseLayout>
