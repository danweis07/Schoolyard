---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { siteConfig } from '@/lib/site'
import { isModuleEnabled } from '@schoolyard/config'
import { getCollection } from 'astro:content'
import { useTranslate, getLocaleFromUrl, localeStaticPaths } from '@/i18n/index'
import CommunityListingCard from '@/modules/community/components/CommunityListingCard.astro'
import CategoryFilter from '@/modules/community/components/CategoryFilter.astro'

export const getStaticPaths = localeStaticPaths

if (!isModuleEnabled(siteConfig, 'community')) {
  return Astro.redirect('/404')
}

const locale = getLocaleFromUrl(Astro.url)
const t = useTranslate(locale)

const now = new Date()
const listings = (await getCollection('communityListings'))
  .filter((l) => !l.data.expiresDate || l.data.expiresDate >= now)
  .sort((a, b) => a.data.order - b.data.order)

const categories = [
  'classified',
  'carpool',
  'skill-share',
  'business',
  'new-family',
  'other',
] as const
type Category = (typeof categories)[number]

const byCategory: Record<Category, typeof listings> = {
  classified: [],
  carpool: [],
  'skill-share': [],
  business: [],
  'new-family': [],
  other: [],
}
for (const listing of listings) {
  byCategory[listing.data.category].push(listing)
}
---

<BaseLayout title={t('community.title')} description={t('community.description')}>
  <section class="mx-auto max-w-4xl px-4 py-12">
    <h1 class="text-4xl font-bold">{t('community.title')}</h1>
    <p class="mt-2 text-lg text-muted">{t('community.description')}</p>

    {
      listings.length === 0 ? (
        <p class="mt-8 text-muted">{t('community.noListings')}</p>
      ) : (
        <div class="mt-10 space-y-10">
          {categories.map((cat) =>
            byCategory[cat].length > 0 ? (
              <div>
                <CategoryFilter category={cat} count={byCategory[cat].length} locale={locale} />
                <div class="mt-4 grid gap-4 md:grid-cols-2">
                  {byCategory[cat].map((listing) => (
                    <CommunityListingCard listing={listing} locale={locale} />
                  ))}
                </div>
              </div>
            ) : null,
          )}
        </div>
      )
    }
  </section>
</BaseLayout>
