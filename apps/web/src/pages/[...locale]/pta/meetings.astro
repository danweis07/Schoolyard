---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { siteConfig } from '@/lib/site'
import { isModuleEnabled } from '@schoolyard/config'
import { useTranslate, getLocaleFromUrl, localeStaticPaths } from '@/i18n/index'

export const getStaticPaths = localeStaticPaths

if (!isModuleEnabled(siteConfig, 'pta')) {
  return Astro.redirect('/404')
}

const locale = getLocaleFromUrl(Astro.url)
const t = useTranslate(locale)
---

<BaseLayout title={t('pta.meetings')}>
  <section class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-4xl font-bold">{t('pta.meetings')}</h1>
    <p class="mt-4 text-lg text-muted">{t('pta.meetingsDescription')}</p>

    <div class="mt-8 rounded-card border border-border bg-surface p-card">
      <h2 class="text-xl font-bold">{t('pta.meetingsWhenHeading')}</h2>
      <p class="mt-4 text-base">{t('pta.meetingsDescription')}</p>
    </div>

    <p class="mt-8 text-sm text-muted">{t('pta.meetingsArchive')}</p>
  </section>
</BaseLayout>
