---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { siteConfig } from '@/lib/site'
import { isModuleEnabled } from '@schoolyard/config'
import { getCollection } from 'astro:content'
import { useTranslate, getLocaleFromUrl, localeStaticPaths } from '@/i18n/index'

export const getStaticPaths = localeStaticPaths

if (!isModuleEnabled(siteConfig, 'transparency')) {
  return Astro.redirect('/404')
}

const locale = getLocaleFromUrl(Astro.url)
const t = useTranslate(locale)

const years = (await getCollection('budgetYears')).sort((a, b) => {
  if (a.data.order !== b.data.order) return a.data.order - b.data.order
  return b.data.year.localeCompare(a.data.year)
})

const currencyFormatter = new Intl.NumberFormat(locale, {
  style: 'currency',
  currency: 'USD',
  maximumFractionDigits: 0,
})
---

<BaseLayout title={t('transparency.title')} description={t('transparency.description')}>
  <section class="mx-auto max-w-4xl px-4 py-12">
    <h1 class="text-4xl font-bold">{t('transparency.title')}</h1>
    <p class="mt-2 text-lg text-muted">{t('transparency.description')}</p>

    {
      years.length === 0 ? (
        <p class="mt-8 text-muted">{t('transparency.noBudgets')}</p>
      ) : (
        <div class="mt-10 space-y-8">
          {years.map((year) => (
            <article class="rounded-card border border-border bg-surface p-card shadow-sm">
              <h2 class="text-2xl font-bold">
                {t('transparency.budgetYear')}: {year.data.year}
              </h2>
              <dl class="mt-4 grid gap-4 sm:grid-cols-2">
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-wide text-muted">
                    {t('transparency.totalRaised')}
                  </dt>
                  <dd class="text-2xl font-bold">
                    {currencyFormatter.format(year.data.totalRaised)}
                  </dd>
                </div>
                <div>
                  <dt class="text-xs font-semibold uppercase tracking-wide text-muted">
                    {t('transparency.totalSpent')}
                  </dt>
                  <dd class="text-2xl font-bold">
                    {currencyFormatter.format(year.data.totalSpent)}
                  </dd>
                </div>
              </dl>

              {year.data.categories.length > 0 && (
                <div class="mt-6">
                  <h3 class="text-sm font-semibold uppercase tracking-wide text-muted">
                    {t('transparency.categories')}
                  </h3>
                  <ul class="mt-2 space-y-2">
                    {year.data.categories.map((cat) => (
                      <li class="flex justify-between border-b border-border/50 py-2 last:border-0">
                        <span>{cat.name}</span>
                        <span class="font-semibold">{currencyFormatter.format(cat.amount)}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {year.data.summary && <p class="mt-4 text-sm text-muted">{year.data.summary}</p>}
            </article>
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
