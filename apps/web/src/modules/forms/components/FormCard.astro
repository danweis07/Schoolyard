---
import { useTranslate, localizedPath } from '@/i18n/index'
import type { Locale } from '@schoolyard/i18n'
import type { SchoolForm } from '@schoolyard/content-api'

interface Props {
  form: SchoolForm
  locale: Locale
}

const { form, locale } = Astro.props
const t = useTranslate(locale)
const dateFormatter = new Intl.DateTimeFormat(locale, {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
})
---

<a
  href={localizedPath(`/forms/${form.slug}`, locale)}
  class="block rounded-card border border-border bg-surface p-card text-base no-underline shadow-sm transition hover:shadow-md"
>
  {
    form.dueDate && (
      <p class="text-sm font-semibold uppercase tracking-wide text-primary">
        {t('forms.dueDate', { date: dateFormatter.format(new Date(form.dueDate)) })}
      </p>
    )
  }
  <h3 class="mt-2 text-xl font-bold">{form.title}</h3>
  {form.description && <p class="mt-3 line-clamp-3 text-sm">{form.description}</p>}
  {
    form.targetGrades.length > 0 && (
      <p class="mt-3 text-xs text-muted">
        {t('forms.targetGrades')}: {form.targetGrades.join(', ')}
      </p>
    )
  }
</a>
