---
import { useTranslate, localizedPath } from '@/i18n/index'
import type { Locale } from '@schoolyard/i18n'
import type { CollectionEntry } from 'astro:content'

interface Props {
  role: CollectionEntry<'volunteers'>
  locale: Locale
}

const { role, locale } = Astro.props
const t = useTranslate(locale)
---

<a
  href={localizedPath(`/volunteer/${role.slug}`, locale)}
  class="block rounded-card border border-border bg-surface p-card text-base no-underline shadow-sm transition hover:shadow-md"
>
  <h3 class="text-xl font-bold">
    {role.data.title}
    {
      role.data.filled && (
        <span class="ml-2 rounded-button bg-success px-2 py-0.5 text-xs font-semibold text-inverse">
          {t('volunteer.filled')}
        </span>
      )
    }
  </h3>
  <p class="mt-2 text-sm text-muted">
    <strong>{t('volunteer.commitment')}:</strong> {role.data.commitment}
  </p>
  <p class="mt-3 text-sm">{role.data.description}</p>
</a>
