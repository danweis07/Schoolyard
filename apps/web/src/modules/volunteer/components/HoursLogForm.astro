---
/**
 * Log volunteer hours — authenticated users only.
 *
 * Writes to `volunteer_hours` via the browser Supabase client. The
 * `self manage volunteer_hours` RLS policy scopes writes to the
 * current user. Admins can export via the `volunteer-hours-export`
 * edge function (see BACKEND.md).
 */
import { useTranslate } from '@/i18n/index'
import { resolveRequestSchool } from '@/lib/site'
import type { Locale } from '@schoolyard/i18n'

interface Props {
  locale: Locale
  /** Pre-fills the form when logging against a specific role. */
  roleId?: string
}

const { locale, roleId } = Astro.props
const t = useTranslate(locale)
const school = resolveRequestSchool(Astro.locals)
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? import.meta.env.SUPABASE_URL ?? ''
const supabaseAnon =
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? import.meta.env.SUPABASE_ANON_KEY ?? ''
---

<form
  class="rounded-card border border-border bg-surface p-card"
  data-sy-hours
  data-school-slug={school.slug}
  data-role-id={roleId ?? ''}
  data-supabase-url={supabaseUrl}
  data-supabase-anon={supabaseAnon}
>
  <h3 class="text-xl font-bold">{t('volunteer.logHoursTitle')}</h3>
  <p class="mt-1 text-sm text-muted">{t('volunteer.logHoursDescription')}</p>

  <label class="mt-4 block">
    <span class="text-sm font-semibold">{t('volunteer.servedOn')}</span>
    <input
      type="date"
      name="served_on"
      required
      class="mt-1 block w-full rounded-button border border-border bg-surface px-3 py-2"
    />
  </label>

  <label class="mt-4 block">
    <span class="text-sm font-semibold">{t('volunteer.hours')}</span>
    <input
      type="number"
      name="hours"
      min="0.25"
      step="0.25"
      required
      class="mt-1 block w-full rounded-button border border-border bg-surface px-3 py-2"
    />
  </label>

  <label class="mt-4 block">
    <span class="text-sm font-semibold">{t('volunteer.notes')}</span>
    <textarea
      name="notes"
      rows="2"
      class="mt-1 block w-full rounded-button border border-border bg-surface px-3 py-2"></textarea>
  </label>

  <button
    type="submit"
    class="mt-6 rounded-button bg-primary px-6 py-2.5 font-semibold text-inverse hover:opacity-90 disabled:opacity-60"
    disabled
  >
    {t('volunteer.logHoursSubmit')}
  </button>

  <p class="mt-3 hidden text-sm" role="status" aria-live="polite" data-sy-hours-status></p>
</form>

<script>
  import { createBrowserClient } from '@schoolyard/supabase/browser'

  const form = document.querySelector<HTMLFormElement>('[data-sy-hours]')
  if (form) {
    const url = form.dataset.supabaseUrl ?? ''
    const anon = form.dataset.supabaseAnon ?? ''
    const roleId = form.dataset.roleId || null
    const status = form.querySelector<HTMLElement>('[data-sy-hours-status]')
    const submit = form.querySelector<HTMLButtonElement>('button[type="submit"]')

    if (url && anon && submit) {
      const supabase = createBrowserClient({ url, anonKey: anon })

      async function refreshAuth() {
        const {
          data: { user },
        } = await supabase.auth.getUser()
        submit!.disabled = !user
      }

      refreshAuth()
      supabase.auth.onAuthStateChange(() => refreshAuth())

      form.addEventListener('submit', async (event) => {
        event.preventDefault()
        if (!status) return
        const {
          data: { user },
        } = await supabase.auth.getUser()
        if (!user) {
          status.classList.remove('hidden')
          status.textContent = 'Please sign in.'
          return
        }
        const fd = new FormData(form)
        status.classList.remove('hidden', 'text-error', 'text-success')
        status.textContent = '…'
        const { error } = await (
          supabase.from('volunteer_hours') as unknown as {
            insert: (row: Record<string, unknown>) => Promise<{ error: { message: string } | null }>
          }
        ).insert({
          school_id: null,
          user_id: user.id,
          role_id: roleId,
          hours: Number(fd.get('hours') ?? 0),
          served_on: String(fd.get('served_on') ?? ''),
          notes: String(fd.get('notes') ?? ''),
        })
        if (error) {
          status.classList.add('text-error')
          status.textContent = `Error: ${error.message}`
          return
        }
        status.classList.add('text-success')
        status.textContent = 'Thanks — hours recorded.'
        form.reset()
      })
    }
  }
</script>
