---
import { useTranslate, localizedPath } from '@/i18n/index'
import type { Locale } from '@schoolyard/i18n'
import type { CollectionEntry } from 'astro:content'

interface Props {
  event: CollectionEntry<'events'>
  locale: Locale
}

const { event, locale } = Astro.props
const t = useTranslate(locale)
const dateFormatter = new Intl.DateTimeFormat(locale, {
  weekday: 'short',
  month: 'short',
  day: 'numeric',
  year: 'numeric',
})
---

<a
  href={localizedPath(`/events/${event.slug}`, locale)}
  class="block rounded-card border border-border bg-surface p-card text-base no-underline shadow-sm transition hover:shadow-md"
>
  <p class="text-sm font-semibold uppercase tracking-wide text-primary">
    {dateFormatter.format(event.data.date)}
  </p>
  <h3 class="mt-2 text-xl font-bold">{event.data.title}</h3>
  {event.data.location && <p class="mt-1 text-sm text-muted">{event.data.location}</p>}
  <p class="mt-3 line-clamp-3 text-sm">{event.data.description}</p>
  {
    event.data.cancelled && (
      <p class="mt-3 inline-block rounded-button bg-error px-2 py-1 text-xs font-semibold text-inverse">
        {t('events.cancelled')}
      </p>
    )
  }
</a>
