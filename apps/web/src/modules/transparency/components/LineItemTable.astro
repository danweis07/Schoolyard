---
import { useTranslate } from '@/i18n/index'
import type { Locale } from '@schoolyard/i18n'

interface LineItem {
  name: string
  amount: number
  percent?: number
}

interface Props {
  items: LineItem[]
  locale: Locale
  headingKey: string
}

const { items, locale, headingKey } = Astro.props
const t = useTranslate(locale)
const currencyFormatter = new Intl.NumberFormat(locale, {
  style: 'currency',
  currency: 'USD',
  maximumFractionDigits: 0,
})
---

<section class="mt-6">
  <h3 class="text-sm font-semibold uppercase tracking-wide text-muted">{t(headingKey)}</h3>
  <ul class="mt-2 space-y-2">
    {
      items.map((item) => (
        <li class="flex items-baseline justify-between gap-3 border-b border-border/50 py-2 last:border-0">
          <span>{item.name}</span>
          <span class="font-semibold tabular-nums">
            {currencyFormatter.format(item.amount)}
            {typeof item.percent === 'number' && (
              <span class="ml-2 text-xs font-normal text-muted">({item.percent}%)</span>
            )}
          </span>
        </li>
      ))
    }
  </ul>
</section>
