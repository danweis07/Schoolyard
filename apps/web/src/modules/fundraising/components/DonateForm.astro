---
/**
 * Donation form — posts to the `donate` edge function which creates a
 * Stripe PaymentIntent. The actual `fundraising_donations` row is
 * inserted by the `stripe-webhook` edge function once payment
 * completes, so the fundraising page totals update automatically via
 * the `fundraising_program_totals` view.
 *
 * This component renders the amount picker + donor info. Actual Stripe
 * Elements mounting happens via a small inline script; the PaymentIntent
 * client secret flows through a fetch to the donate function.
 */
import { useTranslate } from '@/i18n/index'
import { resolveRequestSchool } from '@/lib/site'
import type { Locale } from '@schoolyard/i18n'

interface Props {
  locale: Locale
  /** Optional program slug for program-scoped donations. */
  programSlug?: string
}

const { locale, programSlug } = Astro.props
const t = useTranslate(locale)
const school = resolveRequestSchool(Astro.locals)
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? import.meta.env.SUPABASE_URL ?? ''
const donateEndpoint = supabaseUrl ? `${supabaseUrl.replace(/\/+$/, '')}/functions/v1/donate` : ''
---

<form
  class="rounded-card border border-border bg-surface p-card"
  data-sy-donate
  data-endpoint={donateEndpoint}
  data-school-slug={school.slug}
  data-program-slug={programSlug ?? ''}
>
  <h3 class="text-xl font-bold">{t('fundraising.donateTitle')}</h3>
  <p class="mt-2 text-sm text-muted">{t('fundraising.donateDescription')}</p>

  <fieldset class="mt-4">
    <legend class="text-sm font-semibold">{t('fundraising.amount')}</legend>
    <div class="mt-2 flex flex-wrap gap-2">
      {
        [25, 50, 100, 250].map((usd) => (
          <label class="cursor-pointer rounded-button border border-border px-4 py-2 text-sm font-semibold has-[:checked]:bg-primary has-[:checked]:text-inverse">
            <input type="radio" name="amount" value={usd * 100} class="sr-only" />${usd}
          </label>
        ))
      }
      <label
        class="cursor-pointer rounded-button border border-border px-4 py-2 text-sm font-semibold has-[:checked]:bg-primary has-[:checked]:text-inverse"
      >
        <input type="radio" name="amount" value="custom" class="sr-only" />
        {t('fundraising.customAmount')}
      </label>
    </div>
    <label class="mt-3 block">
      <span class="sr-only">{t('fundraising.customAmount')}</span>
      <input
        type="number"
        name="custom-amount"
        min="1"
        step="1"
        class="mt-1 block w-full rounded-button border border-border bg-surface px-3 py-2"
        placeholder={t('fundraising.customAmount')}
      />
    </label>
  </fieldset>

  <label class="mt-4 block">
    <span class="text-sm font-semibold">{t('contact.form.name')}</span>
    <input
      type="text"
      name="donor_name"
      required
      class="mt-1 block w-full rounded-button border border-border bg-surface px-3 py-2"
    />
  </label>
  <label class="mt-4 block">
    <span class="text-sm font-semibold">{t('contact.form.email')}</span>
    <input
      type="email"
      name="donor_email"
      required
      class="mt-1 block w-full rounded-button border border-border bg-surface px-3 py-2"
    />
  </label>

  <button
    type="submit"
    class="mt-6 rounded-button bg-primary px-6 py-2.5 font-semibold text-inverse hover:opacity-90 disabled:opacity-60"
  >
    {t('fundraising.continueToPayment')}
  </button>

  <p role="status" aria-live="polite" class="mt-4 hidden text-sm" data-sy-donate-status></p>
</form>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-sy-donate]')
  if (form && form.dataset.endpoint) {
    const endpoint = form.dataset.endpoint
    const schoolSlug = form.dataset.schoolSlug ?? ''
    const programSlug = form.dataset.programSlug || undefined
    const status = form.querySelector<HTMLElement>('[data-sy-donate-status]')
    const submit = form.querySelector<HTMLButtonElement>('button[type="submit"]')

    form.addEventListener('submit', async (event) => {
      event.preventDefault()
      if (!status || !submit) return

      const fd = new FormData(form)
      const radioAmount = fd.get('amount')
      const customAmount = Number(fd.get('custom-amount') ?? '0')
      const amountCents =
        radioAmount === 'custom' ? Math.round(customAmount * 100) : Number(radioAmount ?? 0)
      if (!amountCents || amountCents < 100) {
        status.classList.remove('hidden', 'text-success')
        status.classList.add('text-error')
        status.textContent = 'Enter an amount of $1 or more.'
        return
      }

      submit.disabled = true
      status.classList.remove('hidden', 'text-error', 'text-success')
      status.textContent = '…'

      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            school_slug: schoolSlug,
            amount_cents: amountCents,
            program_slug: programSlug,
            donor_name: String(fd.get('donor_name') ?? ''),
            donor_email: String(fd.get('donor_email') ?? ''),
          }),
        })
        if (!res.ok) {
          status.classList.add('text-error')
          status.textContent = `Donation failed (${res.status}).`
          return
        }
        const body = (await res.json()) as { client_secret: string }
        // Hand off the client_secret to Stripe.js, which should be
        // loaded on this page if `fundraising.stripePublishableKey` is
        // set. We dispatch an event so the Stripe bootstrap code can
        // pick it up without hard-coupling this component to Stripe.
        status.classList.add('text-success')
        status.textContent = 'Redirecting to secure payment…'
        window.dispatchEvent(
          new CustomEvent('sy:donate:client-secret', { detail: body.client_secret }),
        )
      } catch (err) {
        status.classList.add('text-error')
        status.textContent = 'Network error. Please try again.'
      } finally {
        submit.disabled = false
      }
    })
  }
</script>
