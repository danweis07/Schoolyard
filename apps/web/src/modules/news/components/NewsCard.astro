---
import { useTranslate, localizedPath } from '@/i18n/index'
import type { Locale } from '@schoolyard/i18n'
import type { CollectionEntry } from 'astro:content'

interface Props {
  post: CollectionEntry<'news'>
  locale: Locale
}

const { post, locale } = Astro.props
const t = useTranslate(locale)
const dateFormatter = new Intl.DateTimeFormat(locale, {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
})
---

<a
  href={localizedPath(`/news/${post.slug}`, locale)}
  class="block rounded-card border border-border bg-surface p-card text-base no-underline shadow-sm transition hover:shadow-md"
>
  <p class="text-sm text-muted">{dateFormatter.format(post.data.publishDate)}</p>
  <h3 class="mt-2 text-xl font-bold">{post.data.title}</h3>
  {
    post.data.author && (
      <p class="mt-1 text-sm text-muted">
        {t('news.by')} {post.data.author}
      </p>
    )
  }
  <p class="mt-3 line-clamp-3 text-sm">{post.data.summary}</p>
  {
    post.data.tags.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-2">
        {post.data.tags.map((tag) => (
          <li class="rounded-button bg-muted px-2 py-0.5 text-xs text-muted">#{tag}</li>
        ))}
      </ul>
    )
  }
</a>
