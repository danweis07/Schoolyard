---
import { useTranslate } from '@/i18n/index'
import type { Locale } from '@schoolyard/i18n'

interface Props {
  category: 'food' | 'health' | 'housing' | 'legal' | 'mental-health' | 'other'
  locale: Locale
}

const { category, locale } = Astro.props
const t = useTranslate(locale)
---

<span
  class="inline-block rounded-button bg-primary/10 px-2 py-0.5 text-xs font-semibold text-primary"
>
  {t(`resources.categories.${category}`)}
</span>
