---
import { useTranslate } from '@/i18n/index'
import type { Locale } from '@schoolyard/i18n'

interface Props {
  categories: readonly string[]
  locale: Locale
}

const { categories, locale } = Astro.props
const t = useTranslate(locale)
---

<nav class="mt-6 flex flex-wrap gap-2" aria-label={t('resources.filterByCategory')}>
  <button
    type="button"
    data-filter-category=""
    class="rounded-button bg-primary px-3 py-1.5 text-xs font-semibold text-inverse transition-colors"
  >
    {t('resources.allCategories')}
  </button>
  {
    categories.map((cat) => (
      <button
        type="button"
        data-filter-category={cat}
        class="rounded-button bg-muted/10 px-3 py-1.5 text-xs font-semibold transition-colors hover:bg-muted/20"
      >
        {t(`resources.categories.${cat}`)}
      </button>
    ))
  }
</nav>
