---
import { useTranslate } from '@/i18n/index'
import type { Locale } from '@schoolyard/i18n'
import type { CollectionEntry } from 'astro:content'

interface Props {
  member: CollectionEntry<'board'>
  locale: Locale
}

const { member, locale } = Astro.props
const t = useTranslate(locale)
const initials = member.data.name
  .split(' ')
  .map((part) => part[0])
  .join('')
  .slice(0, 2)
  .toUpperCase()
---

<article class="rounded-card border border-border bg-surface p-card shadow-sm">
  <div class="flex items-start gap-4">
    {
      member.data.photo ? (
        <img
          src={member.data.photo}
          alt={`Photo of ${member.data.name}`}
          class="h-16 w-16 rounded-full object-cover"
          width="64"
          height="64"
        />
      ) : (
        <div
          class="flex h-16 w-16 items-center justify-center rounded-full bg-primary text-xl font-bold text-inverse"
          aria-hidden="true"
        >
          {initials}
        </div>
      )
    }
    <div class="flex-1">
      <h3 class="text-lg font-bold">{member.data.name}</h3>
      <p class="text-sm font-medium text-primary">{member.data.role}</p>
      {
        member.data.termStart && member.data.termEnd && (
          <p class="mt-1 text-xs text-muted">
            {t('pta.term', { start: member.data.termStart, end: member.data.termEnd })}
          </p>
        )
      }
    </div>
  </div>
  {member.data.bio && <p class="mt-4 text-sm">{member.data.bio}</p>}
  {
    member.data.email && (
      <p class="mt-3 text-sm">
        <a href={`mailto:${member.data.email}`} class="text-primary">
          {member.data.email}
        </a>
      </p>
    )
  }
</article>
