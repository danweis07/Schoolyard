# .env.example — Environment variables for Schoolyard
#
# Copy this file to .env.local and fill in values as needed.
# Many of these are optional; Schoolyard still runs in `static` mode without
# Supabase credentials. Never commit .env.local to git (it's in .gitignore).

# ─── Backend mode ────────────────────────────────────────────
# Which data source the content-api reads from. Defaults to "static" so
# existing legacy builds keep working. Switch to "supabase" once the DB is
# provisioned and migrations have been applied.
# SCHOOLYARD_BACKEND=static
# SCHOOLYARD_BACKEND=supabase

# ─── Supabase ────────────────────────────────────────────────
# Required when SCHOOLYARD_BACKEND=supabase. Create a project at
# https://supabase.com and copy the project URL + anon key from Settings → API.
# The service-role key is NEVER loaded by any client bundle — only by
# scripts/migrate-to-supabase.ts and supabase/functions/**.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# For the mobile app (Expo), these must be prefixed with EXPO_PUBLIC_ so
# Metro exposes them to the bundle at build time.
# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ─── School resolution ──────────────────────────────────────
# How the Astro middleware picks which school a request belongs to.
#   subdomain — longfellow.schoolyard.app → slug "longfellow"
#   path      — /s/longfellow/... → slug "longfellow"
#   config    — legacy single-tenant mode via school.config.json
# SCHOOLYARD_TENANT_RESOLUTION=config

# ─── Safety kill switch ─────────────────────────────────────
# Set to "true" to short-circuit every write endpoint to HTTP 503 without
# touching the DB. Useful during incident response or migrations.
# SCHOOLYARD_READONLY=false

# ─── Analytics ────────────────────────────────────────────────
# PostHog, Plausible, or similar analytics ID (optional, privacy-respecting only)
# PUBLIC_ANALYTICS_ID=

# ─── Forms (legacy static mode) ──────────────────────────────
# Formspree endpoint for the contact form (needed if NOT on Netlify and
# running in static backend mode). Supabase mode uses the contact-submit
# edge function instead.
# PUBLIC_FORMSPREE_ID=

# ─── CMS ──────────────────────────────────────────────────────
# Decap CMS backend — set to "git-gateway" on Netlify, or "github" for local dev
# PUBLIC_CMS_BACKEND=git-gateway

# ─── Mobile App (Expo) ───────────────────────────────────────
# Expo project ID (only needed for EAS builds and push notifications)
# EXPO_PROJECT_ID=
# EXPO_PUBLIC_MANIFEST_BASE_URL=http://localhost:4321

# ─── Development ──────────────────────────────────────────────
# Site URL override for local development (default: http://localhost:4321)
# PUBLIC_SITE_URL=http://localhost:4321
