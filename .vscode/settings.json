{
  // Format on save using Prettier (matches .prettierrc.json)
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  // Astro file support
  "[astro]": {
    "editor.defaultFormatter": "astro-build.astro-vscode"
  },

  // ESLint auto-fix on save
  "eslint.validate": ["javascript", "typescript", "astro"],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },

  // Tailwind CSS IntelliSense — include Astro class attributes
  "tailwindCSS.includeLanguages": {
    "astro": "html"
  },
  "tailwindCSS.experimental.classRegex": [
    ["class:list=\\{\\[([^\\]]*)\\]\\}", "'([^']*)'"]
  ],

  // TypeScript — use workspace version
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,

  // File associations
  "files.associations": {
    "*.astro": "astro",
    "school.config.json": "jsonc",
    "school.config.*.json": "jsonc"
  },

  // Hide noisy directories from explorer and search
  "files.exclude": {
    "**/.turbo": true,
    "**/.astro": true,
    "**/node_modules": true,
    "**/.expo": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.turbo": true,
    "**/dist": true,
    "**/coverage": true,
    "pnpm-lock.yaml": true
  },

  // Consistent with .editorconfig
  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  // Markdown — don't trim whitespace (significant in MD)
  "[markdown]": {
    "files.trimTrailingWhitespace": false
  }
}
