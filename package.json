{
  "name": "schoolyard",
  "version": "0.1.0",
  "private": true,
  "description": "Open source digital infrastructure for every school community",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/schoolyard-org/schoolyard.git"
  },
  "engines": {
    "node": ">=20.11"
  },
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=web",
    "dev:mobile": "turbo run dev --filter=mobile",
    "build": "turbo run build",
    "build:school": "tsx scripts/build-school.ts",
    "migrate:supabase": "tsx scripts/migrate-to-supabase.ts",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:rls": "vitest run --config supabase/tests/vitest.config.ts",
    "gen:types": "supabase gen types typescript --local > packages/supabase/src/database.types.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,astro}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,astro}\"",
    "tokens:build": "pnpm --filter @schoolyard/tokens build",
    "validate-config": "tsx scripts/validate-config.ts",
    "setup": "tsx scripts/setup.ts",
    "setup:fsk": "cd josh && bash setup.sh && cd ..",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "clean": "turbo run clean && rimraf node_modules",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,mjs,cjs,json,md,astro}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@supabase/supabase-js": "^2.45.0",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.6",
    "lint-staged": "^16.4.0",
    "marked": "^18.0.0",
    "prettier": "^3.8.2",
    "prettier-plugin-astro": "^0.14.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.10.0",
    "vitest": "^4.1.4"
  }
}
